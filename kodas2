    local function initSilentAim()
        local SAPlayers     = game:GetService("Players")
        local SARunService  = game:GetService("RunService")
        local SACamera      = workspace.CurrentCamera
        local SALocalPlayer = SAPlayers.LocalPlayer
        local SAMouse       = SALocalPlayer:GetMouse()
        local SAGuiInset    = game:GetService("GuiService"):GetGuiInset()

        _G.SilentTarget = nil

        -- FOV Drawing Circle
        if _G.SilentFOVCircle and _G.SilentFOVCircle.Remove then _G.SilentFOVCircle:Remove() end
        if type(Drawing) == "table" and type(Drawing.new) == "function" then
            _G.SilentFOVCircle = Drawing.new("Circle")
            _G.SilentFOVCircle.Color = Color3.new(1, 1, 1)
            _G.SilentFOVCircle.Thickness = 1
            _G.SilentFOVCircle.Filled = false
            _G.SilentFOVCircle.Transparency = 1
            _G.SilentFOVCircle.Visible = false
        end

        local function isPlayerValid(p)
            return p and p.Character
                and p.Character:FindFirstChild("HumanoidRootPart")
                and p.Character:FindFirstChild("Humanoid")
                and p.Character:FindFirstChild("Head")
        end

        local function calculateHitChance(pct)
            return (math.random(0, 100) / 100) <= (math.floor(pct) / 100)
        end

        local function wallCheck(targetPart, targetChar)
            local origin = SACamera.CFrame.Position
            local _, onScreen = SACamera:WorldToViewportPoint(targetPart.Position)
            if onScreen then
                local rp = RaycastParams.new()
                rp.FilterType = Enum.RaycastFilterType.Blacklist
                rp.FilterDescendantsInstances = {SALocalPlayer.Character or {}, SACamera}
                local result = workspace:Raycast(origin, targetPart.Position - origin, rp)
                if result then
                    return not result.Instance or result.Instance:IsDescendantOf(targetChar)
                end
            end
            return false
        end

        local function getClosestBodyPart(char)
            local closest, part = math.huge, nil
            for _, p in pairs(char:GetChildren()) do
                if p:IsA("BasePart") and not string.find(p.Name:lower(), "gun") then
                    local pos, onScreen = SACamera:WorldToScreenPoint(p.Position)
                    if onScreen then
                        local d = (Vector2.new(SAMouse.X, SAMouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
                        if d < closest then closest = d; part = p end
                    end
                end
            end
            return part
        end

        local function getNearestPoint(part)
            if not part then return nil end
            local half      = part.Size * 0.5
            local transform = part.CFrame:PointToObjectSpace(SAMouse.Hit.Position)
            return part.CFrame * Vector3.new(
                math.clamp(transform.X, -half.X, half.X),
                math.clamp(transform.Y, -half.Y, half.Y),
                math.clamp(transform.Z, -half.Z, half.Z)
            )
        end

        local function getClosestTarget()
            if not calculateHitChance(SilentAimConfig.HitChance) then return nil end
            local target, closestDist = nil, math.huge
            for _, p in pairs(SAPlayers:GetPlayers()) do
                if p ~= SALocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = p.Character.HumanoidRootPart
                    local pos, onScreen = SACamera:WorldToScreenPoint(hrp.Position)
                    if onScreen then
                        local d = (Vector2.new(SAMouse.X, SAMouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude * 0.6
                        -- Knocked check
                        if SilentAimConfig.KnockedCheck and isPlayerValid(p) then
                            local be = p.Character:FindFirstChild("BodyEffects")
                            local grabbed = p.Character:FindFirstChild("GRABBING_CONSTRAINT")
                            if be then
                                local ko = be:FindFirstChild("K.O")
                                if (ko and ko.Value) or grabbed then continue end
                            end
                        end
                        -- Wall check
                        if SilentAimConfig.WallCheck and isPlayerValid(p) then
                            local tp = p.Character:FindFirstChild(SilentAimConfig.HitPart)
                            if tp and not wallCheck(tp, p.Character) then continue end
                        end
                        -- Health check (skip near-dead)
                        local hum = p.Character:FindFirstChildOfClass("Humanoid")
                        if hum and hum.Health < 4 then continue end

                        if d < closestDist and d < SilentAimConfig.FOVRadius * 3 then
                            closestDist = d
                            target = p
                        end
                    end
                end
            end
            return target
        end

        local function getPredictedPosition()
            local tgt = _G.SilentTarget
            if not isPlayerValid(tgt) then return nil end
            local targetChar = tgt.Character
            local hrp        = targetChar.HumanoidRootPart
            local hum        = targetChar:FindFirstChildOfClass("Humanoid")
            if not hrp or not hum then return nil end

            local targetVel = hrp.Velocity
            local targetMov = hum.MoveDirection
            local baseCF

            if SilentAimConfig.NearestPoint then
                local hitPartName = SilentAimConfig.HitPart
                local hp = hitPartName == "Head" or hitPartName == "UpperTorso" or hitPartName == "LowerTorso"
                if hp then
                    local closest = getClosestBodyPart(targetChar)
                    if closest then hitPartName = closest.Name end
                end
                local tp = targetChar:FindFirstChild(hitPartName) or targetChar:FindFirstChild("HumanoidRootPart")
                if tp then
                    local np = getNearestPoint(tp)
                    baseCF = np or tp.Position
                end
            else
                local tp = targetChar:FindFirstChild(SilentAimConfig.HitPart)
                if tp then baseCF = tp.Position end
            end

            if not baseCF then return nil end

            -- AntiCurve / NoGroundShots logic
            local antiCurve = SilentAimConfig.AntiCurve and
                (targetVel.Magnitude > 86 or (targetVel.Magnitude < 1 and targetMov.Magnitude > 0.01)
                    or (targetVel.Magnitude > 5 and targetMov.Magnitude < 0.01))

            local noGround = SilentAimConfig.NoGroundShots and targetVel.Y < -20

            local pred = SilentAimConfig.Prediction
            if antiCurve then
                return baseCF + (targetMov * pred * 16)
            elseif noGround then
                return baseCF + (Vector3.new(targetVel.X, 0, targetVel.Z) * pred)
            else
                return baseCF + (targetVel * pred)
            end
        end

        local function applySilentAim()
            if not SilentAimConfig.Enabled then return end
            _G.SilentTarget = getClosestTarget()
            if not _G.SilentTarget or not _G.SilentTarget.Character then return end
            local hrpPos = SACamera:WorldToScreenPoint(_G.SilentTarget.Character.HumanoidRootPart.Position)
            local d = (Vector2.new(SAMouse.X, SAMouse.Y) - Vector2.new(hrpPos.X, hrpPos.Y)).Magnitude * 0.6
            if d < SilentAimConfig.FOVRadius * 3 then
                local predicted = getPredictedPosition()
                if predicted then
                    -- Fire the correct remote based on detected game
                    local RS = game:GetService("ReplicatedStorage")
                    local gm = SilentAimConfig.GameMode
                    local predictedVec = Vector3.new(predicted.X, predicted.Y, predicted.Z)

                    if gm == "Da Strike" then
                        local remote = RS:FindFirstChild("MAINEVENT")
                        if remote then remote:FireServer("MOUSE", predictedVec) end
                    elseif gm == "Da Uphill" then
                        local remote = RS:FindFirstChild("MAINEVENT")
                        if remote then remote:FireServer("MOUSE", predictedVec) end
                    elseif gm == "Yuu Hood" then
                        local remote = RS:FindFirstChild("MAINEVENT") or RS:FindFirstChild("MainEvent")
                        if remote then remote:FireServer("MOUSE", predictedVec) end
                    elseif gm == "Da Hood" then
                        local remote = RS:FindFirstChild("MainEvent") or RS:FindFirstChild("MAINEVENT")
                        if remote then remote:FireServer("UpdateMousePos", predictedVec) end
                    else
                        -- Fallback: try MAINEVENT
                        local remote = RS:FindFirstChild("MAINEVENT") or RS:FindFirstChild("MainEvent")
                        if remote then remote:FireServer("MOUSE", predictedVec) end
                    end
                    -- Hit sound on successful redirect
                    _G.KodaFPS_PlayHitSound = true
                end
            end
        end

        -- FOV circle update loop
        if type(SARunService.Heartbeat) == "table" or type(SARunService.Heartbeat.Connect) == "function" then
            SARunService.Heartbeat:Connect(function()
                if _G.SilentFOVCircle then
                    _G.SilentFOVCircle.Visible = SilentAimConfig.Enabled and SilentAimConfig.ShowFOV
                    _G.SilentFOVCircle.Radius = (SilentAimConfig.FOVRadius or 35) * 3
