local pcallSuccess, pcallError = pcall(function()
    -- Services
    local Players = game:GetService("Players")
    local TweenService = game:GetService("TweenService")
    local UserInputService = game:GetService("UserInputService")
    local RunService = game:GetService("RunService")
    local CoreGui = game:GetService("CoreGui")

    local LocalPlayer = Players.LocalPlayer

    -- ============================================================
    -- ESP LOGIC
    -- ============================================================
    local function initESP()
        local safe_cloneref = cloneref or function(o) return o end
        local Workspace = safe_cloneref(game:GetService("Workspace"))
        local Cam = Workspace.CurrentCamera
        
        local ESP = {
            Enabled = true,
            TeamCheck = true,
            MaxDistance = 2000,
            FontSize = 11,
            FadeOut = { OnDistance = true, OnDeath = false, OnLeave = false },
            Drawing = {
                Chams = {
                    Enabled  = false, Thermal = true, FillRGB = Color3.fromRGB(0, 0, 0), Fill_Transparency = 100, OutlineRGB = Color3.fromRGB(255, 255, 255), Outline_Transparency = 100, VisibleCheck = true,
                },
                Names = { Enabled = true, RGB = Color3.fromRGB(0, 0, 0) },
                Distances = { Enabled = true, Position = "Text", RGB = Color3.fromRGB(0, 0, 0) },
                Weapons = {
                    Enabled = false, WeaponTextRGB = Color3.fromRGB(0, 0, 0), Outlined = false, Gradient = false, GradientRGB1 = Color3.fromRGB(0, 0, 0), GradientRGB2 = Color3.fromRGB(50, 50, 50),
                },
                Healthbar = {
                    Enabled = true, HealthText = true, Lerp = true, HealthTextRGB = Color3.fromRGB(255, 255, 255), Width = 2.5, Gradient = true, GradientRGB1 = Color3.fromRGB(0, 255, 0), GradientRGB2 = Color3.fromRGB(255, 255, 0), GradientRGB3 = Color3.fromRGB(255, 0, 0), 
                },
                Boxes = {
                    Animate = true, RotationSpeed = 300, Gradient = false, GradientRGB1 = Color3.fromRGB(0, 0, 0), GradientRGB2 = Color3.fromRGB(50, 50, 50), GradientFill = true, GradientFillRGB1 = Color3.fromRGB(0, 0, 0), GradientFillRGB2 = Color3.fromRGB(50, 50, 50), 
                    Filled = { Enabled = true, Transparency = 0.75, RGB = Color3.fromRGB(0, 0, 0) },
                    Full = { Enabled = true, RGB = Color3.fromRGB(0, 0, 0) },
                };
            };
        }

        local RotationAngle, Tick = -45, tick()

        local Functions = {}
        function Functions:Create(Class, Properties)
            local _Instance = typeof(Class) == 'string' and Instance.new(Class) or Class
            for Property, Value in pairs(Properties) do _Instance[Property] = Value end
            return _Instance
        end

        local EspGui = Functions:Create("ScreenGui", { Parent = CoreGui, Name = "Kodasfps_ESP" })

        local function CreateESP(plr)
            if EspGui:FindFirstChild(plr.Name) then EspGui[plr.Name]:Destroy() end
            
            local Name = Functions:Create("TextLabel", {Parent = EspGui, Position = UDim2.new(0.5, 0, 0, -11), Size = UDim2.new(0, 100, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(0, 0, 0), Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(255, 255, 255), RichText = true})
            local Weapon = Functions:Create("TextLabel", {Parent = EspGui, Position = UDim2.new(0.5, 0, 0, 31), Size = UDim2.new(0, 100, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(0, 0, 0), Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(255, 255, 255), RichText = true})
            local Box = Functions:Create("Frame", {Parent = EspGui, BackgroundColor3 = Color3.fromRGB(0, 0, 0), BackgroundTransparency = 0.75, BorderSizePixel = 0})
            local Gradient1 = Functions:Create("UIGradient", {Parent = Box, Enabled = ESP.Drawing.Boxes.GradientFill, Color = ColorSequence.new{ColorSequenceKeypoint.new(0, ESP.Drawing.Boxes.GradientFillRGB1), ColorSequenceKeypoint.new(1, ESP.Drawing.Boxes.GradientFillRGB2)}})
            local Outline = Functions:Create("UIStroke", {Parent = Box, Enabled = ESP.Drawing.Boxes.Gradient, Transparency = 0, Color = Color3.fromRGB(255, 255, 255), LineJoinMode = Enum.LineJoinMode.Miter})
            local Gradient2 = Functions:Create("UIGradient", {Parent = Outline, Enabled = ESP.Drawing.Boxes.Gradient, Color = ColorSequence.new{ColorSequenceKeypoint.new(0, ESP.Drawing.Boxes.GradientRGB1), ColorSequenceKeypoint.new(1, ESP.Drawing.Boxes.GradientRGB2)}})
            local Healthbar = Functions:Create("Frame", {Parent = EspGui, BackgroundColor3 = Color3.fromRGB(0, 255, 0), BackgroundTransparency = 0})
            local BehindHealthbar = Functions:Create("Frame", {Parent = EspGui, ZIndex = -1, BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 0})
            Functions:Create("UIGradient", {Parent = Healthbar, Enabled = ESP.Drawing.Healthbar.Gradient, Rotation = -90, Color = ColorSequence.new{ColorSequenceKeypoint.new(0, ESP.Drawing.Healthbar.GradientRGB1), ColorSequenceKeypoint.new(0.5, ESP.Drawing.Healthbar.GradientRGB2), ColorSequenceKeypoint.new(1, ESP.Drawing.Healthbar.GradientRGB3)}})
            local HealthText = Functions:Create("TextLabel", {Parent = EspGui, Position = UDim2.new(0.5, 0, 0, 31), Size = UDim2.new(0, 100, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(0, 0, 0), Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(255, 255, 255)})
            local Chams = Functions:Create("Highlight", {Parent = EspGui, FillTransparency = 1, OutlineTransparency = 0, OutlineColor = Color3.fromRGB(0, 0, 0), DepthMode = "AlwaysOnTop"})
            
            local function HideESP()
                Box.Visible = false
                Name.Visible = false
                Weapon.Visible = false
                Healthbar.Visible = false
                BehindHealthbar.Visible = false
                HealthText.Visible = false
                Chams.Enabled = false
            end
            
            local Connection
            Connection = RunService.RenderStepped:Connect(function()
                if not plr or not plr.Parent then
                    HideESP()
                    if Connection then Connection:Disconnect() end
                    return
                end
                
                if ESP.Enabled and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
                    local HRP = plr.Character.HumanoidRootPart
                    local Humanoid = plr.Character.Humanoid
                    local Pos, OnScreen = Cam:WorldToScreenPoint(HRP.Position)
                    local Dist = (Cam.CFrame.Position - HRP.Position).Magnitude / 3.5714285714
                    
                    if OnScreen and Dist <= ESP.MaxDistance and (not ESP.TeamCheck or plr.Team ~= LocalPlayer.Team) then
                        local Size = HRP.Size.Y
                        local scaleFactor = (Size * Cam.ViewportSize.Y) / (Pos.Z * 2)
                        local w, h = 3 * scaleFactor, 4.5 * scaleFactor

                        Chams.Adornee = plr.Character
                        Chams.Enabled = ESP.Drawing.Chams.Enabled
                        Chams.FillColor = ESP.Drawing.Chams.FillRGB
                        Chams.OutlineColor = ESP.Drawing.Chams.OutlineRGB
                        if ESP.Drawing.Chams.Thermal then
                            local breathe_effect = math.atan(math.sin(tick() * 2)) * 2 / math.pi
                            Chams.FillTransparency = ESP.Drawing.Chams.Fill_Transparency * breathe_effect * 0.01
                            Chams.OutlineTransparency = ESP.Drawing.Chams.Outline_Transparency * breathe_effect * 0.01
                        end
                        Chams.DepthMode = ESP.Drawing.Chams.VisibleCheck and "Occluded" or "AlwaysOnTop"

                        Box.Visible = ESP.Drawing.Boxes.Full.Enabled
                        Box.Position = UDim2.new(0, Pos.X - w / 2, 0, Pos.Y - h / 2)
                        Box.Size = UDim2.new(0, w, 0, h)
                        if ESP.Drawing.Boxes.Filled.Enabled then
                            Box.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                            Box.BackgroundTransparency = ESP.Drawing.Boxes.GradientFill and ESP.Drawing.Boxes.Filled.Transparency or 1
                            Box.BorderSizePixel = 1
                        else
                            Box.BackgroundTransparency = 1
                        end
                        
                        RotationAngle = RotationAngle + (tick() - Tick) * ESP.Drawing.Boxes.RotationSpeed * math.cos(math.pi / 4 * tick() - math.pi / 2)
                        Gradient1.Rotation = ESP.Drawing.Boxes.Animate and RotationAngle or -45
                        Gradient2.Rotation = ESP.Drawing.Boxes.Animate and RotationAngle or -45
                        Tick = tick()

                        local health = Humanoid.Health / Humanoid.MaxHealth
                        Healthbar.Visible = ESP.Drawing.Healthbar.Enabled
                        Healthbar.Position = UDim2.new(0, Pos.X - w / 2 - 6, 0, Pos.Y - h / 2 + h * (1 - health))  
                        Healthbar.Size = UDim2.new(0, ESP.Drawing.Healthbar.Width, 0, h * health)  
                        BehindHealthbar.Visible = ESP.Drawing.Healthbar.Enabled
                        BehindHealthbar.Position = UDim2.new(0, Pos.X - w / 2 - 6, 0, Pos.Y - h / 2)  
                        BehindHealthbar.Size = UDim2.new(0, ESP.Drawing.Healthbar.Width, 0, h)
                        
                        if ESP.Drawing.Healthbar.HealthText then
                            local healthPercentage = math.floor(health * 100)
                            HealthText.Position = UDim2.new(0, Pos.X - w / 2 - 6, 0, Pos.Y - h / 2 + h * (1 - healthPercentage / 100) + 3)
                            HealthText.Text = tostring(healthPercentage)
                            HealthText.Visible = Humanoid.Health < Humanoid.MaxHealth and ESP.Drawing.Healthbar.Enabled
                            HealthText.TextColor3 = ESP.Drawing.Healthbar.Lerp and (health >= 0.75 and Color3.fromRGB(0, 255, 0) or health >= 0.5 and Color3.fromRGB(255, 255, 0) or health >= 0.25 and Color3.fromRGB(255, 170, 0) or Color3.fromRGB(255, 0, 0)) or ESP.Drawing.Healthbar.HealthTextRGB
                        else
                            HealthText.Visible = false
                        end

                        Name.Visible = ESP.Drawing.Names.Enabled
                        Name.Text = string.format('(<font color="rgb(%d, %d, %d)">E</font>) %s', 0, 0, 0, plr.Name)
                        Name.Position = UDim2.new(0, Pos.X, 0, Pos.Y - h / 2 - 9)
                        
                        if ESP.Drawing.Distances.Enabled then
                            Weapon.Position = UDim2.new(0, Pos.X, 0, Pos.Y + h / 2 + 8)
                            Name.Text = Name.Text .. string.format(" [%d]", math.floor(Dist))
                        end

                        Weapon.Text = "none"
                        Weapon.Visible = ESP.Drawing.Weapons.Enabled
                    else
                        HideESP()
                    end
                else
                    HideESP()
                end
            end)
        end

        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer then coroutine.wrap(CreateESP)(v) end      
        end
        Players.PlayerAdded:Connect(function(v)
            coroutine.wrap(CreateESP)(v)
        end)
        
        return ESP
    end

    local GlobalESP = initESP()

    -- ============================================================
    -- COMBAT / AIMBOT / TRIGGERBOT LOGIC
    -- ============================================================
    local function initCombat()
        local Mouse = LocalPlayer:GetMouse()
        local UserInputService = game:GetService("UserInputService")
        local RunService = game:GetService("RunService")

        -- Triggerbot
        local TB = {
            HoldClick = true,
            Hotkey = Enum.KeyCode.T,
            HotkeyToggle = true,
            Toggle = false
        }
        local CurrentlyPressed = false
        local lastClick = 0

        UserInputService.InputBegan:Connect(function(input, gpe)
            if gpe then return end
            if TB.HotkeyToggle then
                if input.KeyCode == TB.Hotkey then
                    TB.Toggle = not TB.Toggle
                end
            else
                if input.KeyCode == TB.Hotkey then
                    TB.Toggle = true
                end
            end
        end)

        UserInputService.InputEnded:Connect(function(input, gpe)
            if not TB.HotkeyToggle and input.KeyCode == TB.Hotkey then
                TB.Toggle = false
            end
        end)

        local function getPlayerFromHit(hit)
            if not hit then return nil end
            local model = hit:FindFirstAncestorOfClass("Model")
            if model and model:FindFirstChild("Humanoid") then
                return Players:GetPlayerFromCharacter(model)
            end
            return nil
        end

        RunService.RenderStepped:Connect(function()
            if TB.Toggle then
                local hitPlayer = getPlayerFromHit(Mouse.Target)
                
                if hitPlayer and hitPlayer ~= LocalPlayer and hitPlayer.Character and hitPlayer.Character:FindFirstChild("Humanoid") and hitPlayer.Character.Humanoid.Health > 0 then
                    if TB.HoldClick then
                        if not CurrentlyPressed then
                            CurrentlyPressed = true
                            if type(mouse1press) == "function" then mouse1press() end
                        end
                    else
                        if tick() - lastClick > 0.1 then
                            lastClick = tick()
                            if type(mouse1click) == "function" then mouse1click() end
                        end
                    end
                else
                    if TB.HoldClick and CurrentlyPressed then
                        CurrentlyPressed = false
                        if type(mouse1release) == "function" then mouse1release() end
                    end
                end
            end
        end)

        -- Camlock
        local cl_config = {
            enabled = false,
            key = Enum.KeyCode.Q,
            part = "Head",
            y_offset = -0.6,
            fov = 120,
            thick = 1,
            idle_clr = Color3.fromRGB(255, 0, 0),
            target_clr = Color3.fromRGB(0, 255, 0),
            show_fov = true,
            prediction = 0.115,
            smoothing = 10
        }

        local cl_target = nil
        local circle
        if type(Drawing) == "table" and type(Drawing.new) == "function" then
            circle = Drawing.new("Circle")
            circle.Visible = false
            circle.Filled = false
            circle.Radius = cl_config.fov
            circle.Thickness = cl_config.thick
            circle.Color = cl_config.idle_clr
        end

        local function notify(title, msg)
            if game.StarterGui then
                pcall(function() game.StarterGui:SetCore("SendNotification", { Title = title, Text = msg, Duration = 2 }) end)
            end
        end

        local function get_closest()
            local dist = cl_config.fov
            local temp_target = nil
            local cam_size = Workspace.CurrentCamera.ViewportSize
            local center = Vector2.new(cam_size.X / 2, cam_size.Y / 2)

            for _, v in pairs(Players:GetPlayers()) do
                if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(cl_config.part) then
                    local pos, vis = Workspace.CurrentCamera:WorldToViewportPoint(v.Character[cl_config.part].Position)
                    if vis then
                        local mag = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                        if mag < dist then
                            dist = mag
                            temp_target = v.Character[cl_config.part]
                        end
                    end
                end
            end
            return temp_target
        end

        UserInputService.InputBegan:Connect(function(input, gpe)
            if gpe then return end
            if cl_config.enabled and input.KeyCode == cl_config.key then
                if cl_target then
                    cl_target = nil
                    notify("Camlock", "Unlocked")
                else
                    local found = get_closest()
                    if found then
                        cl_target = found
                        local name = Players:GetPlayerFromCharacter(cl_target.Parent).Name
                        notify("Camlock", "Locked onto: " .. name)
                    end
                end
            end
        end)

        RunService.RenderStepped:Connect(function()
            if circle then
                circle.Visible = cl_config.enabled and cl_config.show_fov
                if circle.Visible then
                    circle.Radius = cl_config.fov
                    circle.Position = Vector2.new(Workspace.CurrentCamera.ViewportSize.X / 2, Workspace.CurrentCamera.ViewportSize.Y / 2)
                    local check = get_closest()
                    if check then circle.Color = cl_config.target_clr else circle.Color = cl_config.idle_clr end
                end
            end

            if cl_config.enabled and cl_target and cl_target.Parent and cl_target.Parent:FindFirstChild("Humanoid") and cl_target.Parent.Humanoid.Health > 0 then
                local lock_pos = cl_target.Position + Vector3.new(0, cl_config.y_offset, 0)
                if cl_target.Parent:FindFirstChild("HumanoidRootPart") and tonumber(cl_config.prediction) then
                    lock_pos = lock_pos + (cl_target.Parent.HumanoidRootPart.Velocity * tonumber(cl_config.prediction))
                end
                
                local targetCFrame = CFrame.new(Workspace.CurrentCamera.CFrame.Position, lock_pos)
                local s = tonumber(cl_config.smoothing) or 10
                if s < 10 then
                    Workspace.CurrentCamera.CFrame = Workspace.CurrentCamera.CFrame:Lerp(targetCFrame, s / 10)
                else
                    Workspace.CurrentCamera.CFrame = targetCFrame
                end
            else
                cl_target = nil
            end
        end)

        return TB, cl_config
    end

    local TriggerbotConfig, CamlockConfig = initCombat()

