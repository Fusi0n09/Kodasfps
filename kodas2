                    _G.SilentFOVCircle.Filled = SilentAimConfig.Radient
                    _G.SilentFOVCircle.Transparency = SilentAimConfig.Radient and 0.3 or 1
                end
            end)

            -- Auto-prediction ping loop
            SARunService.Heartbeat:Connect(function()
                if not SilentAimConfig.AutoPrediction then return end
                local ok, pingStr = pcall(function()
                    return game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValueString()
                end)
                if not ok or not pingStr then return end
                local split = string.split(pingStr, "(")
                local ping  = tonumber(split and split[1])
                if not ping then return end
                local pingMap = {
                    {190,0.180},{180,0.170},{170,0.165},{160,0.1574},{150,0.1555},
                    {140,0.141},{130,0.1344},{120,0.1344},{110,0.1300},{100,0.1295},
                    {90,0.1295},{80,0.1300},{70,0.1290},{60,0.1250},{50,0.1230},
                    {40,0.1190},{30,0.1100},{20,0.1000}
                }
                for _, entry in ipairs(pingMap) do
                    if ping < entry[1] then SilentAimConfig.Prediction = entry[2]; break end
                end
            end)
        end

        -- Hook Tool.Activated
        local toolConn
        local function onToolAdded(tool)
            if tool:IsA("Tool") then
                if toolConn then toolConn:Disconnect() end
                toolConn = tool.Activated:Connect(applySilentAim)
            end
        end
        local function onCharReady(char)
            char.ChildAdded:Connect(onToolAdded)
        end
        if SALocalPlayer.Character then onCharReady(SALocalPlayer.Character) end
        SALocalPlayer.CharacterAdded:Connect(onCharReady)
    end

