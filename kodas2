    -- UNIVERSAL & YUU HOOD MOD LOGIC
    -- ============================================================
    local function initUniversalMods()
        local Mods = {
            WalkSpeed = 50, JumpPower = 100, SpeedHack = false, InfJump = false,
            Fly = false, FlySpeed = 50, Noclip = false, Fullbright = false, FOV = 90, Wireframe = false,
            AntiAfk = true, AutoFarm = false, NoRecoil = false, InstantReload = false, Wallbang = false
        }
        
        local VirtualUser = game:GetService("VirtualUser")
        local Lighting = game:GetService("Lighting")
        local RunService = game:GetService("RunService")
        local Workspace = game:GetService("Workspace")
        local UserInputService = game:GetService("UserInputService")
        
        -- Default Lighting Cache
        local defaultAmbient, defaultBottom, defaultTop = Lighting.Ambient, Lighting.ColorShift_Bottom, Lighting.ColorShift_Top

        -- Infinite Jump + Anti-AFK
        UserInputService.JumpRequest:Connect(function()
            if Mods.InfJump and LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
                LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end)

        LocalPlayer.Idled:Connect(function()
            if Mods.AntiAfk then
                VirtualUser:Button2Down(Vector2.new(0,0), Workspace.CurrentCamera.CFrame)
                task.wait(1)
                VirtualUser:Button2Up(Vector2.new(0,0), Workspace.CurrentCamera.CFrame)
            end
        end)

        local bg, bv
        local function toggleFly(v)
            Mods.Fly = v
            if v and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local root = LocalPlayer.Character.HumanoidRootPart
                bg = Instance.new("BodyGyro", root)
                bg.P = 9e4; bg.maxTorque = Vector3.new(9e9, 9e9, 9e9); bg.cframe = root.CFrame
                bv = Instance.new("BodyVelocity", root)
                bv.velocity = Vector3.new(0, 0, 0); bv.maxForce = Vector3.new(9e9, 9e9, 9e9)
            else
                if bg then bg:Destroy() bg = nil end
                if bv then bv:Destroy() bv = nil end
            end
        end

        RunService.RenderStepped:Connect(function()
            local char = LocalPlayer.Character
            if not char then return end
            
            if Mods.Fullbright then
                Lighting.Ambient = Color3.new(1, 1, 1)
                Lighting.ColorShift_Bottom = Color3.new(1, 1, 1)
                Lighting.ColorShift_Top = Color3.new(1, 1, 1)
            else
                Lighting.Ambient = defaultAmbient
                Lighting.ColorShift_Bottom = defaultBottom
                Lighting.ColorShift_Top = defaultTop
            end
            
            Workspace.CurrentCamera.FieldOfView = Mods.FOV
            
            local hum = char:FindFirstChildOfClass("Humanoid")
            if Mods.SpeedHack and hum then
                hum.WalkSpeed = Mods.WalkSpeed
                hum.JumpPower = Mods.JumpPower
                if not hum.UseJumpPower then hum.UseJumpPower = true end
            end
            
            if Mods.Noclip then
                for _, p in pairs(char:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end
            
            if Mods.Fly and char:FindFirstChild("HumanoidRootPart") and bg and bv then
                local cam = Workspace.CurrentCamera
                local speed = tonumber(Mods.FlySpeed) or 50
                local ctrl = {f = 0, b = 0, l = 0, r = 0}
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then ctrl.f = 1 end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then ctrl.b = -1 end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then ctrl.l = -1 end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then ctrl.r = 1 end
                
                local dir = cam.CFrame.lookVector * (ctrl.f + ctrl.b) + cam.CFrame.rightVector * (ctrl.r + ctrl.l)
                if dir.Magnitude > 0 then dir = dir.Unit end
                bv.Velocity = dir * speed
                bg.CFrame = cam.CFrame
            end
        end)
        
        -- Da Hood / Yuu Hood Gun Exploits via GC hooks
        task.spawn(function()
            while task.wait(1) do
                if Mods.NoRecoil or Mods.InstantReload or Mods.Wallbang then
                    if type(getgc) == "function" then
                        for _, v in pairs(getgc(true)) do
                            if type(v) == "table" then
                                if Mods.NoRecoil and rawget(v, "Recoil") ~= nil then v.Recoil = 0 end
                                if Mods.NoRecoil and rawget(v, "RecoilMax") ~= nil then v.RecoilMax = 0 end
                                if Mods.NoRecoil and rawget(v, "RecoilMin") ~= nil then v.RecoilMin = 0 end
                                
                                if Mods.InstantReload and rawget(v, "ReloadTime") ~= nil then v.ReloadTime = 0.05 end
                                
                                if Mods.Wallbang and rawget(v, "Penetration") ~= nil then v.Penetration = 100 end
                            end
                        end
                    end
                end
            end
        end)

        -- Da Hood / Yuu Hood specific AutoFarm (Money Drops)
        task.spawn(function()
            while task.wait(0.2) do
                if Mods.AutoFarm and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    local root = LocalPlayer.Character.HumanoidRootPart
                    local dropFolder = Workspace:FindFirstChild("Ignored") and Workspace.Ignored:FindFirstChild("Drop")
                    if dropFolder then
                        for _, v in pairs(dropFolder:GetChildren()) do
                            if v.Name == "MoneyDrop" and v:IsA("Part") then
                                local cd = v:FindFirstChild("ClickDetector")
                                if cd then
                                    root.CFrame = v.CFrame
                                    if type(fireclickdetector) == "function" then
                                        fireclickdetector(cd)
                                    end
                                    task.wait(0.3)
                                end
                            end
                        end
                    end
                end
            end
        end)

        Mods.ToggleFly = toggleFly
        return Mods
    end

    local UniMods = initUniversalMods()

