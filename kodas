local AB = {
    -- state
    autobagEnabled    = false,
    autobagHeight     = 0,
    autobagTargets    = {},
    targetPlayer      = nil,
    active            = false,
    start             = 0,
    downing           = false,
    ffHiding          = false,
    lastbought        = 0,
    baggedNotified    = {},
    attemptNotified   = nil,
    targetPart        = nil,
    -- protection
    antiflameEnabled  = false,
    antiflameTargets  = {},
    antibagEnabled    = false,
    bagThreat         = false,
    hiding            = false,
    flameStates       = {},
    autoFireArmor     = false,
    fireArmorThresh   = 25,
    fireArmorLast     = 0,
    -- misc
    returnToDeath     = false,
    resetWhenBagged   = false,
    deathCFrame       = nil,
    returnTime        = 0,
    resetDebounce     = 0,
    -- kill glue
    glueConn          = nil,
    glueActive        = false,
    glueTarget        = nil,
}
local AB_hrp = nil
local AB_char = nil

local function AB_hasFF(p)
    return p and p.Character and p.Character:FindFirstChildOfClass("ForceField") ~= nil
end
local function AB_isBagged(p)
    if not p or not p.Character then return false end
    return p.Character:FindFirstChild("Christmas_Sock") ~= nil
end
local function AB_isKOd(p)
    if not p or not p.Character then return false end
    local be = p.Character:FindFirstChild("BodyEffects")
    if be then
        local ko = be:FindFirstChild("K.O"); if ko and ko.Value then return true end
        local kn = be:FindFirstChild("Knocked"); if kn and kn.Value then return true end
    end
    local hum = p.Character:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health <= 0
end
local function AB_hasFlame(p)
    if not p or not p.Character then return false end
    local t = p.Character:FindFirstChildOfClass("Tool")
    return t and (t.Name == "[Flamethrower]" or t.Name:lower():find("flame"))
end
local function AB_getBags()
    local bags = {}
    local bp = LocalPlayer:FindFirstChildOfClass("Backpack")
    for _, v in ipairs(bp and bp:GetChildren() or {}) do
        if v:IsA("Tool") and v.Name:lower():find("bag") then table.insert(bags, v) end
    end
    for _, v in ipairs(AB_char and AB_char:GetChildren() or {}) do
        if v:IsA("Tool") and v.Name:lower():find("bag") then table.insert(bags, 1, v) end
    end
    return bags
end
local function AB_unequipBag()
    local bp = LocalPlayer:FindFirstChildOfClass("Backpack"); if not bp then return end
    if AB_char then
        for _, v in pairs(AB_char:GetChildren()) do
            if v:IsA("Tool") and v.Name:lower():find("bag") then v.Parent = bp end
        end
    end
end
local function AB_cleanup()
    if AB.targetPart and AB.targetPart.Parent then AB.targetPart.Anchored = false end
    AB.active=false; AB.targetPlayer=nil; AB.targetPart=nil
    AB.downing=false; AB.ffHiding=false; AB.attemptNotified=nil
    pcall(function() sethiddenproperty(AB_hrp,"PhysicsRepRootPart",nil) end)
    AB_unequipBag()
end

-- Wire up character tracking
local function AB_onCharAdded(c)
    AB_char = c
    AB_hrp  = c:WaitForChild("HumanoidRootPart",6)
    if AB.returnToDeath and AB.deathCFrame then
        AB_hrp.CFrame = AB.deathCFrame; AB.returnTime = tick()+1.5
    end
    local hum = c:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.Died:Connect(function()
            if AB.returnToDeath and AB_hrp and AB_hrp.Parent then
                AB.deathCFrame = AB_hrp.CFrame
            end
        end)
    end
    AB.bagThreat = false
end
LocalPlayer.CharacterAdded:Connect(AB_onCharAdded)
if LocalPlayer.Character then AB_onCharAdded(LocalPlayer.Character) end

-- Hook each player's Animator for bag animation detection
local function AB_hookChar(c, p)
    local function tryHook(anim)
        if not anim or not anim:IsA("Animator") then return end
        anim.AnimationPlayed:Connect(function(t)
            if t.Animation.AnimationId == "rbxassetid://3493406987" then
                if AB.antibagEnabled then
                    notify(p.Name .. " attempting to bag you!")
                    AB.bagThreat = true
                    t.Stopped:Once(function() AB.bagThreat = false end)
                end
            end
        end)
    end
    for _, d in ipairs(c:GetDescendants()) do tryHook(d) end
    c.DescendantAdded:Connect(function(d) tryHook(d) end)
end
local function AB_hookPlayer(p)
    if p.Character then AB_hookChar(p.Character, p) end
    p.CharacterAdded:Connect(function(c) AB_hookChar(c, p) end)
end
for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then AB_hookPlayer(p) end end
Players.PlayerAdded:Connect(function(p) if p ~= LocalPlayer then AB_hookPlayer(p) end end)

-- Main heartbeat loop
RunService.Heartbeat:Connect(function()
    if not keyPassed then return end
    AB_char = LocalPlayer.Character or AB_char
    AB_hrp  = AB_char and AB_char:FindFirstChild("HumanoidRootPart") or AB_hrp
    if not AB_hrp then return end

    -- Return to death pos
    if AB.returnToDeath and AB.deathCFrame and tick() < AB.returnTime then
        AB_hrp.CFrame = AB.deathCFrame
    end

    -- Reset when bagged
    if AB.resetWhenBagged and tick()-AB.resetDebounce > 0.5 then
        if AB_isBagged(LocalPlayer) then
            AB.resetDebounce = tick()
            local hum = AB_char:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then hum.Health=0; notify("reset -- you were bagged") end
            return
        end
    end

    -- AntiFlame / AntiBag protection
    local shouldHide = false
    if AB.antiflameEnabled then
        for name, enabled in pairs(AB.antiflameTargets) do
            local p = Players:FindFirstChild(name)
            if enabled and p and p.Character then
                local st = AB.flameStates[name] or {eq=false,rel=false}
                AB.flameStates[name] = st
                local eq  = AB_hasFlame(p)
                local rel = eq and false -- no reload check without api, assume always threat
                if eq and not st.eq then notify(name.." pulled flamethrower!") end
                st.eq=eq; st.rel=rel
                if eq then shouldHide = true end
            end
        end
    end
    if AB.antibagEnabled and AB.bagThreat then shouldHide = true end

    if shouldHide then
        if not AB.hiding then
            notify(AB.bagThreat and "bag threat -- hiding!" or "flame threat -- hiding!")
            AB.hiding = true
            AB_cleanup()
            pcall(function()
                AB_hrp.CFrame = CFrame.new(math.huge, math.huge, math.huge)
            end)
        end
        return
    else
        if AB.hiding then AB.hiding=false; notify("threat gone -- resuming") end
    end

    -- Auto-bag main logic
    if not AB.autobagEnabled then AB_cleanup(); return end

    local bags = AB_getBags()
    if #bags == 0 then return end -- no bags available

    -- Build target lists
    local normal, ffList = {}, {}
    for name, enabled in pairs(AB.autobagTargets) do
        local p = Players:FindFirstChild(name)
        if enabled and p and p.Character then
            -- notify on bag
            local wasBagged = AB.baggedNotified[name]
            local nowBagged = AB_isBagged(p)
            if nowBagged and not wasBagged then notify(name.." successfully bagged!") end
            AB.baggedNotified[name] = nowBagged
            if not nowBagged and not AB_isKOd(p) then
                if AB_hasFF(p) then table.insert(ffList, p)
                else table.insert(normal, p) end
            end
        end
    end

    -- Downing phase
    if AB.downing and AB.targetPlayer then
        if AB_isKOd(AB.targetPlayer) then
            notify(AB.targetPlayer.Name.." is down!")
            AB.targetPlayer=nil; AB.downing=false; AB.attemptNotified=nil
        else
            AB_unequipBag()
        end
        return
    end

    -- Check if current target just got bagged -> start downing
    if AB.targetPlayer and not AB.downing and AB_isBagged(AB.targetPlayer) then
        notify(AB.targetPlayer.Name.." bagged! downing...")
        if AB.targetPart and AB.targetPart.Parent then AB.targetPart.Anchored=false end
        pcall(function() sethiddenproperty(AB_hrp,"PhysicsRepRootPart",nil) end)
        AB_unequipBag(); AB.downing=true; AB.ffHiding=false
        return
    end

    local pick = #normal>0 and normal[1] or nil
    if not pick then
        if #ffList>0 then
            if not AB.ffHiding then notify("target has ForceField -- waiting..."); AB.ffHiding=true end
            AB_cleanup()
        else AB_cleanup() end
        return
    end
    if AB.ffHiding then notify("ForceField dropped -- resuming"); AB.ffHiding=false end

    -- Switch target if needed
    local needSwitch = not AB.targetPlayer or AB.targetPlayer~=pick or tick()-AB.start>5
    if needSwitch then
        if AB.targetPart and AB.targetPart.Parent then AB.targetPart.Anchored=false end
        AB.targetPlayer=pick; AB.start=tick(); AB.attemptNotified=nil
    end

    local tChar = AB.targetPlayer.Character
    local tPart = tChar and (tChar:FindFirstChild("HumanoidRootPart") or tChar:FindFirstChildWhichIsA("BasePart"))
    if not tPart then return end
    AB.targetPart = tPart

    local tool = AB_char:FindFirstChildWhichIsA("Tool")
    if not (tool and tool.Name:lower():find("bag")) then
        tool = bags[1]; if tool then tool.Parent = AB_char end
    end

    if AB.attemptNotified ~= AB.targetPlayer.Name then
        notify("auto-bagging "..AB.targetPlayer.Name.."...")
        AB.attemptNotified = AB.targetPlayer.Name
    end

    tPart.Anchored = true
    tPart.CFrame   = CFrame.new(0, 25, 0)
    pcall(function() sethiddenproperty(AB_hrp,"PhysicsRepRootPart",tPart) end)
    AB_hrp.CFrame = CFrame.lookAt(
        tPart.Position - tPart.CFrame.LookVector + Vector3.new(0,AB.autobagHeight,0),
        tPart.Position + Vector3.new(0,AB.autobagHeight,0)
    )
    if tool then tool:Activate() end
end)

