    if not rollHitChance() then return nil end
    local best, bestDist = nil, math.huge
    local mLoc = UserInputService:GetMouseLocation()
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not player.Character then continue end
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        -- knocked check
        if SA.KnockedCheck then
            if isKnockedOrKO(player) then continue end
        end
        -- grabbed check
        if player.Character:FindFirstChild("GRABBING_CONSTRAINT") then continue end
        -- team check
        if SA.TeamCheck then
            if LocalPlayer.Team and player.Team and LocalPlayer.Team == player.Team then continue end
        end
        -- crew check (Da Hood specific)
        if SA.CrewCheck then
            pcall(function()
                local tc = player.DataFolder.Information.Crew
                local lc = LocalPlayer.DataFolder.Information.Crew
                if tc.Value ~= "" and lc.Value ~= "" and tc.Value == lc.Value then
                    error("same crew")
                end
            end)
        end
        local root = player.Character:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        -- wall check
        if SA.WallCheck then
            if not raycastVisible(root, player.Character) then continue end
        end
        local sp, onScreen = Camera:WorldToScreenPoint(root.Position)
        if not onScreen then continue end
        local dist = (Vector2.new(sp.X, sp.Y) - mLoc).Magnitude
        if dist < bestDist and dist < SA.FOVRadius then
            bestDist = dist
            best     = player
        end
    end
    return best
end

-- Get predicted fire position with AntiCurve + NoGroundShots
local function getSAPredictedPos(target)
    if not target or not target.Character then return nil end
    local char = target.Character
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    -- pick aim part
    local aimPart
    if SA.HitPart == "Closest Part" then
        aimPart = getClosestBodyPart(char) or root
    else
        aimPart = char:FindFirstChild(SA.HitPart) or root
    end
    local vel   = root.Velocity or root.AssemblyLinearVelocity or Vector3.new()
    local movDir= Vector3.new()
    pcall(function()
        movDir = char:FindFirstChildOfClass("Humanoid").MoveDirection
    end)
    -- AntiCurve: detect curve-running
    local useMoveDir = false
    if SA.AntiCurve then
        local spd = vel.Magnitude
        if spd > 86 or (spd < 1 and movDir.Magnitude > 0.01) or (spd > 5 and movDir.Magnitude < 0.01) then
            useMoveDir = true
        end
    end
    -- NoGroundShots: flatten Y when falling fast
    local flattenY = false
    if SA.NoGroundShots and vel.Y < -20 then flattenY = true end
    -- get base position
    local basePos
    if SA.NearestPoint then
        basePos = getNearestPoint(aimPart) or aimPart.Position
    else
        basePos = aimPart.Position
    end
    -- apply prediction
    local pred = SA.Prediction
    local finalPos
    if useMoveDir then
        finalPos = basePos + movDir * pred * 16
    elseif flattenY then
        finalPos = basePos + Vector3.new(vel.X, 0, vel.Z) * pred
    else
        finalPos = basePos + vel * pred
    end
    -- smoothing lerp
    if SA.Smoothing > 0 then
        if getSAPredictedPos._last then
            finalPos = getSAPredictedPos._last:Lerp(finalPos, SA.Smoothing)
        end
        getSAPredictedPos._last = finalPos
    end
    return finalPos
end

-- Fire silent aim when tool is activated
local function applySilentAim()
    if not SA.Enabled then return end
    local target = getSATarget()
    if not target then return end
    local pos = getSAPredictedPos(target)
    if not pos then return end
    -- find and fire the remote
    pcall(function()
        local RS = game:GetService("ReplicatedStorage")
        local remote = RS:FindFirstChild("MAINEVENT")
            or RS:FindFirstChild("MainEvent")
            or RS:FindFirstChild("Remote")
            or RS:FindFirstChild("Bullets")
            or RS:FindFirstChild(".gg/untitledhood")
        if remote then
            remote:FireServer("MOUSE", pos)
        end
    end)
end

