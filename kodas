    local page=n("Frame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,BorderSizePixel=0,Visible=false},CA)
    local colHolder=n("Frame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1},page)
    n("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,SortOrder=Enum.SortOrder.LayoutOrder},colHolder)
    local td={name=name,btn=btn,bar=bar,page=page,colHolder=colHolder,lCol=nil,rCol=nil,subTabBar=nil,subTabs={}}
    btn.MouseButton1Click:Connect(function() setActiveTab(td) end)
    btn.MouseEnter:Connect(function()
        if activeTD~=td then
            tw(btn,{TextColor3=TEXT},0.12)
            tw(bar,{BackgroundTransparency=0.6},0.15)
