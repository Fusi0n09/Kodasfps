local function China_Alive(Player)
    return Player and Player.Character
        and Player.Character:FindFirstChild("Humanoid")
        and Player.Character:FindFirstChild("Head")
end

local function EnableAntiAimViewer()
    if _G.KodasAntiAimHookActive then return end
    _G.KodasAntiAimHookActive = true
    pcall(function()
        China_Hook = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local Args   = {...}
            local Method = getnamecallmethod()
            if not checkcaller()
            and Method == "FireServer"
            and self.Name == "MainEvent"
            and Args[1] == "UpdateMousePos"
            and ENV["kodasAntiAimEnabled"] then
                Args[2] = China_Mouse.Hit.Position
                return self:FireServer(unpack(Args))
            end
            return China_Hook(self, ...)
        end))
    end)
    if China_Alive(China_LP) then
        China_LP.Character.Humanoid:UnequipTools()
        China_Bypass(China_LP.Character)
    end
    China_LP.CharacterAdded:Connect(function(Character)
        if ENV["kodasAntiAimEnabled"] then
            China_Bypass(Character)
        end
    end)
end

