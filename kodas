local function isKnockedOrKO(player)
    if not EccoConfig.KnockCheck then return false end
    if player and player.Character then
        local be = player.Character:FindFirstChild("BodyEffects")
        if be then
            local ko = be:FindFirstChild("K.O")
            if ko and ko.Value then return true end
            local kn = be:FindFirstChild("Knocked")
            if kn and kn.Value then return true end
        end
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health <= 0 then return true end
    end
    return false
end

-- Raycast from camera to part, returns true if nothing blocks the way
local function raycastVisible(part, character)
    if not part or not part.Parent then return false end
    local ignore = {}
    if LocalPlayer.Character then table.insert(ignore, LocalPlayer.Character) end
    if character then table.insert(ignore, character) end
    local origin    = Camera.CFrame.Position
    local direction = part.Position - origin
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = ignore
    rp.FilterType  = Enum.RaycastFilterType.Exclude
    rp.IgnoreWater = true
    local result = Workspace:Raycast(origin, direction, rp)
    return result == nil or result.Instance:IsDescendantOf(part.Parent)
end

local function canSeeTarget(part, useLockChecks)
    if not part or not part.Parent then return false end
    if useLockChecks then
        if Lock.WallCheck or Lock.VisCheck then
            return raycastVisible(part, part.Parent)
        end
        return true
    else
        if not EccoConfig.VisibleCheck then return true end
        return raycastVisible(part, part.Parent)
    end
end

local function getClosestBodyPart(character)
    local closest, shortest = nil, math.huge
    local parts = {"Head", "UpperTorso", "HumanoidRootPart", "LowerTorso"}
    for _, pname in ipairs(parts) do
        local part = character:FindFirstChild(pname)
        if part then
            local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
            if onScreen then
                local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
                local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
                if d < shortest then shortest = d; closest = part end
            end
        end
    end
    return closest
end

local function getPredictedPos(part, pred)
    local vel = part.AssemblyLinearVelocity or part.Velocity or Vector3.new()
    return part.Position + vel * pred
end

-- Returns the best aim part for a character according to Lock.TargetPart setting
local function getBestPart(character)
    if Lock.TargetPart == "Closest Part" then
        return getClosestBodyPart(character)
    end
    return character:FindFirstChild(Lock.TargetPart)
        or character:FindFirstChild("HumanoidRootPart")
end

-- Find closest valid target within FOV
local function GetClosestTarget()
    local best, bestDist = nil, math.huge
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

    for _, Player in pairs(Players:GetPlayers()) do
        if Player == LocalPlayer then continue end
        if not Player.Character then continue end

        local hum = Player.Character:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        if isKnockedOrKO(Player) then continue end

        -- team check
        if Lock.TeamCheck then
            if LocalPlayer.Team and Player.Team
            and LocalPlayer.Team == Player.Team then continue end
        end

        local root = Player.Character:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        local sp, onScreen = Camera:WorldToViewportPoint(root.Position)
        if not onScreen then continue end

        local screenDist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if screenDist > Lock.FOV then continue end

        -- wall / vis check
        if Lock.WallCheck or Lock.VisCheck then
            local aimPart = getBestPart(Player.Character)
            if aimPart and not raycastVisible(aimPart, Player.Character) then continue end
        end

        if screenDist < bestDist then
            bestDist = screenDist
            best     = Player
        end
    end
    return best
end

