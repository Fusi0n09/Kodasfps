local function China_Bypass(Entity)
    Entity.ChildAdded:Connect(function(Child)
        if Child:IsA("Tool") then
            if China_ToolConn then China_ToolConn:Disconnect() end
            China_ToolConn = Child.Activated:Connect(function()
                if China_MainEvent and ENV["kodasAntiAimEnabled"] then
                    China_MainEvent:FireServer("UpdateMousePos", China_Mouse.Hit.Position)
                end
            end)
        end
    end)
