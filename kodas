-- ------ CAMERA LOCK ---------------------------------------------------------------------------------------------------------------------------------------------------------
RunService.RenderStepped:Connect(function()
    if not keyPassed then return end
    if not Lock.Enabled then return end
    if not Locked then return end

    -- validate current target
    local valid = LockedTarget
        and LockedTarget.Character
        and LockedTarget.Character:FindFirstChildOfClass("Humanoid")
        and LockedTarget.Character:FindFirstChildOfClass("Humanoid").Health > 0
        and not isKnockedOrKO(LockedTarget)

    -- auto-retarget if needed
    if not valid then
        if Lock.AutoRetarget then
            LockedTarget = GetClosestTarget()
            if not LockedTarget then Locked = false end
        else
            Locked = false; LockedTarget = nil
        end
        return
    end

    local char = LockedTarget.Character
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- get best aim part
    local aimPart = getBestPart(char) or root

    -- wall check while tracking
    if Lock.WallCheck or Lock.VisCheck then
        if not raycastVisible(aimPart, char) then
            if Lock.AutoRetarget then
                LockedTarget = GetClosestTarget()
                if not LockedTarget then Locked = false end
            else
                Locked = false; LockedTarget = nil
            end
            return
        end
    end

    -- prediction: velocity-based position offset
    local vel          = aimPart.AssemblyLinearVelocity or aimPart.Velocity or Vector3.new()
    local predicted    = aimPart.Position + vel * Lock.Prediction

    -- smooth camera toward predicted position
    local current   = Camera.CFrame
    local targetCF  = CFrame.new(current.Position, predicted)
    Camera.CFrame   = current:Lerp(targetCF, Lock.Smoothness)
end)

-- Triggerbot
local function runTriggerBot()
    if not EccoConfig.TriggerBot.Enabled or not triggerEnabled then return end
    if tick()-lastTriggerClick < EccoConfig.TriggerBot.Delay then return end
    if not LockedTarget or not LockedTarget.Character then return end
    if isKnockedOrKO(LockedTarget) then return end
    local targetPart = LockedTarget.Character:FindFirstChild("HumanoidRootPart")
    if not targetPart or not canSeeTarget(targetPart) then return end
    local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
    if not tool then return end
    tool:Activate()
    lastTriggerClick = tick()
end

