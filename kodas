local ESPHolder = Instance.new("ScreenGui")
ESPHolder.Name = "KodasESP"
ESPHolder.ResetOnSpawn = false
ESPHolder.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
ESPHolder.DisplayOrder = 1
ESPHolder.Parent = CoreGui

local ESPRotAngle, ESPTick = -45, tick()
local ESPConnections = {}

local function ESP_FadeOnDist(el, dist)
    local t = math.max(0.1, 1-(dist/ESPModule.MaxDistance))
    if el:IsA("TextLabel") then el.TextTransparency = 1-t
    elseif el:IsA("ImageLabel") then el.ImageTransparency = 1-t
    elseif el:IsA("UIStroke") then el.Transparency = 1-t
    elseif el:IsA("Highlight") then el.FillTransparency=1-t; el.OutlineTransparency=1-t
    elseif el:IsA("Frame") then el.BackgroundTransparency=1-t end
end

local function MakeESP(plr)
    -- remove dupe
    if ESPHolder:FindFirstChild(plr.Name) then ESPHolder[plr.Name]:Destroy() end

    local Cam2 = Workspace.CurrentCamera
    local lplayer2 = Players.LocalPlayer

    local function mk(cls, props) local o=Instance.new(cls); for k,v in pairs(props) do o[k]=v end; o.Parent=ESPHolder; return o end

    local Name          = mk("TextLabel",{Size=UDim2.new(0,100,0,20),AnchorPoint=Vector2.new(0.5,0.5),BackgroundTransparency=1,TextColor3=Color3.fromRGB(255,255,255),Font=Enum.Font.Code,TextSize=ESPModule.FontSize,TextStrokeTransparency=0,TextStrokeColor3=Color3.fromRGB(0,0,0),RichText=true})
    local Distance      = mk("TextLabel",{Size=UDim2.new(0,100,0,20),AnchorPoint=Vector2.new(0.5,0.5),BackgroundTransparency=1,TextColor3=Color3.fromRGB(255,255,255),Font=Enum.Font.Code,TextSize=ESPModule.FontSize,TextStrokeTransparency=0,TextStrokeColor3=Color3.fromRGB(0,0,0),RichText=true})
    local Weapon        = mk("TextLabel",{Size=UDim2.new(0,100,0,20),AnchorPoint=Vector2.new(0.5,0.5),BackgroundTransparency=1,TextColor3=Color3.fromRGB(255,255,255),Font=Enum.Font.Code,TextSize=ESPModule.FontSize,TextStrokeTransparency=0,TextStrokeColor3=Color3.fromRGB(0,0,0),RichText=true})
    local HealthText    = mk("TextLabel",{Size=UDim2.new(0,100,0,20),AnchorPoint=Vector2.new(0.5,0.5),BackgroundTransparency=1,TextColor3=Color3.fromRGB(255,255,255),Font=Enum.Font.Code,TextSize=ESPModule.FontSize,TextStrokeTransparency=0,TextStrokeColor3=Color3.fromRGB(0,0,0)})
    local Box           = mk("Frame",{BackgroundColor3=Color3.fromRGB(0,0,0),BackgroundTransparency=0.75,BorderSizePixel=0})
    local Outline       = mk("UIStroke",{Transparency=0,Color=Color3.fromRGB(255,255,255),LineJoinMode=Enum.LineJoinMode.Miter})
    Outline.Parent = Box
    local Gradient1     = Instance.new("UIGradient"); Gradient1.Enabled=ESPModule.Drawing.Boxes.GradientFill; Gradient1.Color=ColorSequence.new{ColorSequenceKeypoint.new(0,ESPModule.Drawing.Boxes.GradientFillRGB1),ColorSequenceKeypoint.new(1,ESPModule.Drawing.Boxes.GradientFillRGB2)}; Gradient1.Parent=Box
    local Gradient2     = Instance.new("UIGradient"); Gradient2.Enabled=ESPModule.Drawing.Boxes.Gradient; Gradient2.Color=ColorSequence.new{ColorSequenceKeypoint.new(0,ESPModule.Drawing.Boxes.GradientRGB1),ColorSequenceKeypoint.new(1,ESPModule.Drawing.Boxes.GradientRGB2)}; Gradient2.Parent=Outline
    local Healthbar     = mk("Frame",{BackgroundColor3=Color3.fromRGB(255,255,255),BackgroundTransparency=0})
    local BehindHB      = mk("Frame",{ZIndex=-1,BackgroundColor3=Color3.fromRGB(0,0,0),BackgroundTransparency=0})
    local HBGrad        = Instance.new("UIGradient"); HBGrad.Enabled=ESPModule.Drawing.Healthbar.Gradient; HBGrad.Rotation=-90; HBGrad.Color=ColorSequence.new{ColorSequenceKeypoint.new(0,ESPModule.Drawing.Healthbar.GradientRGB1),ColorSequenceKeypoint.new(0.5,ESPModule.Drawing.Healthbar.GradientRGB2),ColorSequenceKeypoint.new(1,ESPModule.Drawing.Healthbar.GradientRGB3)}; HBGrad.Parent=Healthbar
    local Chams         = mk("Highlight",{FillTransparency=1,OutlineTransparency=0,OutlineColor=Color3.fromRGB(119,120,255),DepthMode="AlwaysOnTop"})
    local LeftTop       = mk("Frame",{BackgroundColor3=ESPModule.Drawing.Boxes.Corner.RGB,BorderSizePixel=0})
    local LeftSide      = mk("Frame",{BackgroundColor3=ESPModule.Drawing.Boxes.Corner.RGB,BorderSizePixel=0})
    local RightTop      = mk("Frame",{BackgroundColor3=ESPModule.Drawing.Boxes.Corner.RGB,BorderSizePixel=0})
    local RightSide     = mk("Frame",{BackgroundColor3=ESPModule.Drawing.Boxes.Corner.RGB,BorderSizePixel=0})
    local BottomSide    = mk("Frame",{BackgroundColor3=ESPModule.Drawing.Boxes.Corner.RGB,BorderSizePixel=0})
    local BottomDown    = mk("Frame",{BackgroundColor3=ESPModule.Drawing.Boxes.Corner.RGB,BorderSizePixel=0})
    local BotRSide      = mk("Frame",{BackgroundColor3=ESPModule.Drawing.Boxes.Corner.RGB,BorderSizePixel=0})
    local BotRDown      = mk("Frame",{BackgroundColor3=ESPModule.Drawing.Boxes.Corner.RGB,BorderSizePixel=0})

    local all = {Box,Name,Distance,Weapon,Healthbar,BehindHB,HealthText,LeftTop,LeftSide,RightTop,RightSide,BottomSide,BottomDown,BotRSide,BotRDown}

    local function HideAll()
        for _,el in ipairs(all) do el.Visible=false end
        Chams.Enabled=false
    end

    local conn
    conn = RunService.RenderStepped:Connect(function()
        if not ESPModule.Enabled then HideAll(); return end
        if not plr or not plr.Parent then
            HideAll(); if conn then conn:Disconnect() end; return
        end
        if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then HideAll(); return end

        local HRP       = plr.Character.HumanoidRootPart
        local Humanoid2 = plr.Character:FindFirstChildOfClass("Humanoid")
        if not Humanoid2 then HideAll(); return end

        local Pos, OnScreen = Cam2:WorldToScreenPoint(HRP.Position)
        local Dist = (Cam2.CFrame.Position - HRP.Position).Magnitude / 3.5714285714

        if not OnScreen or Dist > ESPModule.MaxDistance then HideAll(); return end

        -- team check
        if ESPModule.TeamCheck then
            if lplayer2.Team and plr.Team and lplayer2.Team == plr.Team then HideAll(); return end
        end

        local Size       = HRP.Size.Y
        local scaleFactor= (Size * Cam2.ViewportSize.Y) / (Pos.Z * 2)
        local w, h       = 3*scaleFactor, 4.5*scaleFactor

        -- fade on dist
        if ESPModule.FadeOut.OnDistance then
            for _,el in ipairs(all) do ESP_FadeOnDist(el, Dist) end
            ESP_FadeOnDist(Chams, Dist)
        end

        -- CHAMS
        Chams.Adornee = plr.Character
        Chams.Enabled = ESPModule.Drawing.Chams.Enabled
        Chams.FillColor = ESPModule.Drawing.Chams.FillRGB
        Chams.OutlineColor = ESPModule.Drawing.Chams.OutlineRGB
        if ESPModule.Drawing.Chams.Thermal then
            local b = math.atan(math.sin(tick()*2))*2/math.pi
            Chams.FillTransparency    = ESPModule.Drawing.Chams.Fill_Transparency * b * 0.01
            Chams.OutlineTransparency = ESPModule.Drawing.Chams.Outline_Transparency * b * 0.01
        end
        Chams.DepthMode = ESPModule.Drawing.Chams.VisibleCheck and "Occluded" or "AlwaysOnTop"

        -- CORNER BOXES
        local ce = ESPModule.Drawing.Boxes.Corner.Enabled
        LeftTop.Visible=ce;    LeftTop.Position=UDim2.new(0,Pos.X-w/2,0,Pos.Y-h/2);        LeftTop.Size=UDim2.new(0,w/5,0,1)
        LeftSide.Visible=ce;   LeftSide.Position=UDim2.new(0,Pos.X-w/2,0,Pos.Y-h/2);       LeftSide.Size=UDim2.new(0,1,0,h/5)
        BottomSide.Visible=ce; BottomSide.Position=UDim2.new(0,Pos.X-w/2,0,Pos.Y+h/2);     BottomSide.Size=UDim2.new(0,1,0,h/5); BottomSide.AnchorPoint=Vector2.new(0,5)
        BottomDown.Visible=ce; BottomDown.Position=UDim2.new(0,Pos.X-w/2,0,Pos.Y+h/2);     BottomDown.Size=UDim2.new(0,w/5,0,1); BottomDown.AnchorPoint=Vector2.new(0,1)
        RightTop.Visible=ce;   RightTop.Position=UDim2.new(0,Pos.X+w/2,0,Pos.Y-h/2);       RightTop.Size=UDim2.new(0,w/5,0,1); RightTop.AnchorPoint=Vector2.new(1,0)
        RightSide.Visible=ce;  RightSide.Position=UDim2.new(0,Pos.X+w/2-1,0,Pos.Y-h/2);    RightSide.Size=UDim2.new(0,1,0,h/5)
        BotRSide.Visible=ce;   BotRSide.Position=UDim2.new(0,Pos.X+w/2,0,Pos.Y+h/2);       BotRSide.Size=UDim2.new(0,1,0,h/5); BotRSide.AnchorPoint=Vector2.new(1,1)
        BotRDown.Visible=ce;   BotRDown.Position=UDim2.new(0,Pos.X+w/2,0,Pos.Y+h/2);       BotRDown.Size=UDim2.new(0,w/5,0,1); BotRDown.AnchorPoint=Vector2.new(1,1)

        -- FULL BOX
        Box.Position = UDim2.new(0,Pos.X-w/2,0,Pos.Y-h/2)
        Box.Size     = UDim2.new(0,w,0,h)
        Box.Visible  = ESPModule.Drawing.Boxes.Full.Enabled
        if ESPModule.Drawing.Boxes.Filled.Enabled then
            Box.BackgroundTransparency = ESPModule.Drawing.Boxes.GradientFill and ESPModule.Drawing.Boxes.Filled.Transparency or 1
        else Box.BackgroundTransparency=1 end
        ESPRotAngle = ESPRotAngle + (tick()-ESPTick)*ESPModule.Drawing.Boxes.RotationSpeed*math.cos(math.pi/4*tick()-math.pi/2)
        if ESPModule.Drawing.Boxes.Animate then Gradient1.Rotation=ESPRotAngle; Gradient2.Rotation=ESPRotAngle
        else Gradient1.Rotation=-45; Gradient2.Rotation=-45 end
        ESPTick = tick()

        -- HEALTHBAR
        local health = Humanoid2.Health / Humanoid2.MaxHealth
        Healthbar.Visible  = ESPModule.Drawing.Healthbar.Enabled
        Healthbar.Position = UDim2.new(0,Pos.X-w/2-6,0,Pos.Y-h/2+h*(1-health))
        Healthbar.Size     = UDim2.new(0,ESPModule.Drawing.Healthbar.Width,0,h*health)
        BehindHB.Visible   = ESPModule.Drawing.Healthbar.Enabled
        BehindHB.Position  = UDim2.new(0,Pos.X-w/2-6,0,Pos.Y-h/2)
        BehindHB.Size      = UDim2.new(0,ESPModule.Drawing.Healthbar.Width,0,h)
        if ESPModule.Drawing.Healthbar.HealthText then
            local hp = math.floor(Humanoid2.Health/Humanoid2.MaxHealth*100)
            HealthText.Position = UDim2.new(0,Pos.X-w/2-6,0,Pos.Y-h/2+h*(1-hp/100)+3)
            HealthText.Text    = tostring(hp)
            HealthText.Visible = Humanoid2.Health < Humanoid2.MaxHealth
            HealthText.TextColor3 = ESPModule.Drawing.Healthbar.HealthTextRGB
        end

        -- NAMES
        Name.Visible = ESPModule.Drawing.Names.Enabled
        if ESPModule.Drawing.Distances.Enabled and ESPModule.Drawing.Distances.Position=="Text" then
            if ESPModule.Options.Friendcheck and pcall(function() return lplayer2:IsFriendsWith(plr.UserId) end) then
                Name.Text = string.format('(<font color="rgb(0,255,0)">F</font>) %s [%d]', plr.Name, math.floor(Dist))
            else
                Name.Text = string.format('(<font color="rgb(255,0,0)">E</font>) %s [%d]', plr.Name, math.floor(Dist))
            end
        else
            Name.Text = string.format('(<font color="rgb(255,0,0)">E</font>) %s', plr.Name)
        end
        Name.Position = UDim2.new(0,Pos.X,0,Pos.Y-h/2-9)

        -- WEAPON label
        Weapon.Visible   = ESPModule.Drawing.Weapons.Enabled
        Weapon.Position  = UDim2.new(0,Pos.X,0,Pos.Y+h/2+8)
        local tool2 = plr.Character:FindFirstChildOfClass("Tool")
        Weapon.Text      = tool2 and tool2.Name or ""
        Weapon.TextColor3= ESPModule.Drawing.Weapons.WeaponTextRGB
    end)

    table.insert(ESPConnections, conn)
end

local function StartESP()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then coroutine.wrap(MakeESP)(plr) end
    end
    Players.PlayerAdded:Connect(function(plr) coroutine.wrap(MakeESP)(plr) end)
end

