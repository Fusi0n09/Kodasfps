-- Mode presets
local function setSAMode(mode)
    if mode == "legit" then
        SA.HitChance = 70; SA.FOVRadius = 20; SA.Prediction = 0.09
    elseif mode == "semi-legit" then
        SA.HitChance = 85; SA.FOVRadius = 35; SA.Prediction = 0.12
    elseif mode == "blatant" then
        SA.HitChance = 100; SA.FOVRadius = 120; SA.Prediction = 0.18
    end
    SA.Mode = mode
end

-- Hit chance roll
local function rollHitChance()
    return math.random(1, 100) <= SA.HitChance
end

-- Get nearest point on a part to mouse position
local function getNearestPoint(part)
    if not part then return nil end
    local hit   = Mouse.Hit.Position
    local half  = part.Size * 0.5
    local local_ = part.CFrame:PointToObjectSpace(hit)
    return part.CFrame * Vector3.new(
        math.clamp(local_.X, -half.X, half.X),
        math.clamp(local_.Y, -half.Y, half.Y),
        math.clamp(local_.Z, -half.Z, half.Z)
    )
end

-- Find closest target to crosshair within SA FOV
