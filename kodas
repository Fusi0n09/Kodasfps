    local bar=n("Frame",{Size=UDim2.new(1,0,0,2),Position=UDim2.new(0,0,1,-2),BackgroundColor3=ACCENT,BackgroundTransparency=1,BorderSizePixel=0},btn)
    if index<#TAB_NAMES then
        n("Frame",{Size=UDim2.new(0,1,0,12),Position=UDim2.new(1,-1,0.5,-6),BackgroundColor3=BORDER,BorderSizePixel=0},btn)
