local MOD_IDS = { [79302719976479]=true, [133018602124236]=true }
local modNotifSlot = 0

local function showModAlert(plrName, userId)
    modNotifSlot = modNotifSlot + 1
    local slot = modNotifSlot
    local vp = Camera.ViewportSize
    local notifW, notifH = 265, 58
    local startX = vp.X + 10
    local destX  = vp.X - notifW - 10
    local posY   = vp.Y - notifH - 12 - (slot-1) * (notifH + 6)
    local nf = Instance.new("Frame")
    nf.Size = UDim2.new(0,notifW,0,notifH)
    nf.Position = UDim2.new(0,startX,0,posY)
    nf.BackgroundColor3 = Color3.fromRGB(12,4,6)
    nf.BorderSizePixel = 0; nf.ZIndex = 2000
    nf.Parent = SG
    rnd(nf,5)
    local nfSt = Instance.new("UIStroke",nf)
    nfSt.Color=Color3.fromRGB(210,35,35); nfSt.Thickness=1.4
    local ig=Instance.new("UIGradient",nf)
    ig.Color=ColorSequence.new(Color3.fromRGB(22,5,8),Color3.fromRGB(10,4,6))
    ig.Rotation=135
    n("TextLabel",{Size=UDim2.new(0,42,1,0),Position=UDim2.new(0,0,0,0),
        BackgroundTransparency=1,Text="?",TextColor3=Color3.fromRGB(255,50,50),
        TextSize=24,Font=Enum.Font.GothamBold,ZIndex=2001},nf)
    n("TextLabel",{Size=UDim2.new(1,-46,0,28),Position=UDim2.new(0,44,0,4),
        BackgroundTransparency=1,Text="MOD DETECTED",
        TextColor3=Color3.fromRGB(255,55,55),TextSize=13,Font=Enum.Font.GothamBold,
        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=2001},nf)
    n("TextLabel",{Size=UDim2.new(1,-46,0,20),Position=UDim2.new(0,44,0,32),
        BackgroundTransparency=1,Text=plrName.."  ["..tostring(userId).."]" ,
        TextColor3=Color3.fromRGB(195,155,155),TextSize=10,Font=Enum.Font.Code,
        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=2001},nf)
    -- slide in
    tw(nf,{Position=UDim2.new(0,destX,0,posY)},0.35)
    task.delay(6,function()
        tw(nf,{Position=UDim2.new(0,startX,0,posY)},0.28)
        task.delay(0.32,function() nf:Destroy(); modNotifSlot=math.max(0,modNotifSlot-1) end)
    end)
end

