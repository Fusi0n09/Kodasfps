    -- Upvalue cooldown zeroing (executor-specific: getconnections + debug API)
    local function rfZeroToolCooldown(Tool)
        if not RapidFire.Enabled then return end
        if not Tool:IsA("Tool") then return end
        if type(getconnections) ~= "function" then return end
        pcall(function()
            for _, conn in pairs(getconnections(Tool.Activated)) do
                local info = debug.getinfo(conn.Function)
                for idx = 1, info.nups do
                    local val = debug.getupvalue(conn.Function, idx)
                    if type(val) == "number" then
                        debug.setupvalue(conn.Function, idx, 0)
                    end
                end
            end
        end)
    end

