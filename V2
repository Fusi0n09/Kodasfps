        Method   = "Notification",  -- "Webhook" or "Notification"
    }

    -- Scan players for moderator group membership
    local function checkForMods()
        if not modNotifConfig.Enabled then return end
        for _, p in pairs(Players:GetPlayers()) do
            if p == LocalPlayer then continue end
            for _, groupId in ipairs(modNotifConfig.Groups) do
                local ok, isMember = pcall(function()
                    return p:IsInGroup(groupId)
                end)
                if ok and isMember then
                    local msg = "⚠ Moderator detected: " .. p.Name .. " (Group: " .. groupId .. ")"
                    if modNotifConfig.Action == "Notify" then
                        pcall(function()
                            game.StarterGui:SetCore("SendNotification", {
                                Title = "Mod Notifier", Text = msg, Duration = 6
                            })
                        end)
                    elseif modNotifConfig.Action == "Kick" then
                        LocalPlayer:Kick("Mod detected - auto-kick triggered")
                    elseif modNotifConfig.Action == "Crash" then
                        -- Crash client by invoking invalid memory
                        pcall(function()
                            local t = {}
                            while true do table.insert(t, t) end
                        end)
                    end
                    break
                end
            end
        end
    end

