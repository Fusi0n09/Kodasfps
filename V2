local pcallSuccess, pcallError = pcall(function()
    -- Services
    local Players = game:GetService("Players")
    local TweenService = game:GetService("TweenService")
    local UserInputService = game:GetService("UserInputService")
    local RunService = game:GetService("RunService")
    local CoreGui = game:GetService("CoreGui")

    local LocalPlayer = Players.LocalPlayer

    -- ============================================================
    -- ESP LOGIC
    -- ============================================================
    local function initESP()
        local safe_cloneref = cloneref or function(o) return o end
        local Workspace = safe_cloneref(game:GetService("Workspace"))
        local Cam = Workspace.CurrentCamera
        
        local ESP = {
            Enabled = true,
            TeamCheck = true,
            MaxDistance = 2000,
            FontSize = 11,
            FadeOut = { OnDistance = true, OnDeath = false, OnLeave = false },
            Drawing = {
                Chams = {
                    Enabled  = false, Thermal = true, FillRGB = Color3.fromRGB(0, 0, 0), Fill_Transparency = 100, OutlineRGB = Color3.fromRGB(255, 255, 255), Outline_Transparency = 100, VisibleCheck = true,
                },
                Names = { Enabled = true, RGB = Color3.fromRGB(0, 0, 0) },
                Distances = { Enabled = true, Position = "Text", RGB = Color3.fromRGB(0, 0, 0) },
                Weapons = {
                    Enabled = false, WeaponTextRGB = Color3.fromRGB(0, 0, 0), Outlined = false, Gradient = false, GradientRGB1 = Color3.fromRGB(0, 0, 0), GradientRGB2 = Color3.fromRGB(50, 50, 50),
                },
                Healthbar = {
                    Enabled = true, HealthText = true, Lerp = true, HealthTextRGB = Color3.fromRGB(255, 255, 255), Width = 2.5, Gradient = true, GradientRGB1 = Color3.fromRGB(0, 255, 0), GradientRGB2 = Color3.fromRGB(255, 255, 0), GradientRGB3 = Color3.fromRGB(255, 0, 0), 
                },
                Boxes = {
                    Animate = true, RotationSpeed = 300, Gradient = false, GradientRGB1 = Color3.fromRGB(0, 0, 0), GradientRGB2 = Color3.fromRGB(50, 50, 50), GradientFill = true, GradientFillRGB1 = Color3.fromRGB(0, 0, 0), GradientFillRGB2 = Color3.fromRGB(50, 50, 50), 
                    Filled = { Enabled = true, Transparency = 0.75, RGB = Color3.fromRGB(0, 0, 0) },
                    Full = { Enabled = true, RGB = Color3.fromRGB(0, 0, 0) },
                };
            };
        }

        local RotationAngle, Tick = -45, tick()

        local Functions = {}
        function Functions:Create(Class, Properties)
            local _Instance = typeof(Class) == 'string' and Instance.new(Class) or Class
            for Property, Value in pairs(Properties) do _Instance[Property] = Value end
            return _Instance
        end

        local EspGui = Functions:Create("ScreenGui", { Parent = CoreGui, Name = "Kodasfps_ESP" })

        local function CreateESP(plr)
            if EspGui:FindFirstChild(plr.Name) then EspGui[plr.Name]:Destroy() end
            
            local Name = Functions:Create("TextLabel", {Parent = EspGui, Position = UDim2.new(0.5, 0, 0, -11), Size = UDim2.new(0, 100, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(0, 0, 0), Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(255, 255, 255), RichText = true})
            local Weapon = Functions:Create("TextLabel", {Parent = EspGui, Position = UDim2.new(0.5, 0, 0, 31), Size = UDim2.new(0, 100, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(0, 0, 0), Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(255, 255, 255), RichText = true})
            local Box = Functions:Create("Frame", {Parent = EspGui, BackgroundColor3 = Color3.fromRGB(0, 0, 0), BackgroundTransparency = 0.75, BorderSizePixel = 0})
            local Gradient1 = Functions:Create("UIGradient", {Parent = Box, Enabled = ESP.Drawing.Boxes.GradientFill, Color = ColorSequence.new{ColorSequenceKeypoint.new(0, ESP.Drawing.Boxes.GradientFillRGB1), ColorSequenceKeypoint.new(1, ESP.Drawing.Boxes.GradientFillRGB2)}})
            local Outline = Functions:Create("UIStroke", {Parent = Box, Enabled = ESP.Drawing.Boxes.Gradient, Transparency = 0, Color = Color3.fromRGB(255, 255, 255), LineJoinMode = Enum.LineJoinMode.Miter})
            local Gradient2 = Functions:Create("UIGradient", {Parent = Outline, Enabled = ESP.Drawing.Boxes.Gradient, Color = ColorSequence.new{ColorSequenceKeypoint.new(0, ESP.Drawing.Boxes.GradientRGB1), ColorSequenceKeypoint.new(1, ESP.Drawing.Boxes.GradientRGB2)}})
            local Healthbar = Functions:Create("Frame", {Parent = EspGui, BackgroundColor3 = Color3.fromRGB(0, 255, 0), BackgroundTransparency = 0})
            local BehindHealthbar = Functions:Create("Frame", {Parent = EspGui, ZIndex = -1, BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 0})
            Functions:Create("UIGradient", {Parent = Healthbar, Enabled = ESP.Drawing.Healthbar.Gradient, Rotation = -90, Color = ColorSequence.new{ColorSequenceKeypoint.new(0, ESP.Drawing.Healthbar.GradientRGB1), ColorSequenceKeypoint.new(0.5, ESP.Drawing.Healthbar.GradientRGB2), ColorSequenceKeypoint.new(1, ESP.Drawing.Healthbar.GradientRGB3)}})
            local HealthText = Functions:Create("TextLabel", {Parent = EspGui, Position = UDim2.new(0.5, 0, 0, 31), Size = UDim2.new(0, 100, 0, 20), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(0, 0, 0), Font = Enum.Font.Code, TextSize = ESP.FontSize, TextStrokeTransparency = 0, TextStrokeColor3 = Color3.fromRGB(255, 255, 255)})
            local Chams = Functions:Create("Highlight", {Parent = EspGui, FillTransparency = 1, OutlineTransparency = 0, OutlineColor = Color3.fromRGB(0, 0, 0), DepthMode = "AlwaysOnTop"})
            
            local function HideESP()
                Box.Visible = false
                Name.Visible = false
                Weapon.Visible = false
                Healthbar.Visible = false
                BehindHealthbar.Visible = false
                HealthText.Visible = false
                Chams.Enabled = false
            end
            
            local Connection
            Connection = RunService.RenderStepped:Connect(function()
                if not plr or not plr.Parent then
                    HideESP()
                    if Connection then Connection:Disconnect() end
                    return
                end
                
                if ESP.Enabled and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
                    local HRP = plr.Character.HumanoidRootPart
                    local Humanoid = plr.Character.Humanoid
                    local Pos, OnScreen = Cam:WorldToScreenPoint(HRP.Position)
                    local Dist = (Cam.CFrame.Position - HRP.Position).Magnitude / 3.5714285714
                    
                    if OnScreen and Dist <= ESP.MaxDistance and (not ESP.TeamCheck or plr.Team ~= LocalPlayer.Team) then
                        -- Project top of head and bottom of feet to get true avatar height on screen
                        local char = plr.Character
                        local head  = char:FindFirstChild("Head")
                        local lfoot = char:FindFirstChild("LeftFoot") or char:FindFirstChild("Left Leg") or HRP

                        local topPos    = head  and (head.Position  + Vector3.new(0, head.Size.Y / 2, 0))  or (HRP.Position + Vector3.new(0, 3, 0))
                        local botPos    = lfoot and (lfoot.Position - Vector3.new(0, lfoot.Size.Y / 2, 0)) or (HRP.Position - Vector3.new(0, 3, 0))

                        local topScreen = Cam:WorldToScreenPoint(topPos)
                        local botScreen = Cam:WorldToScreenPoint(botPos)

                        local h = math.abs(botScreen.Y - topScreen.Y)
                        local w = h * 0.6   -- natural avatar width ratio
                        -- Clamp minimums so box doesn't vanish at long range
                        h = math.max(h, 6)
                        w = math.max(w, 4)

                        Chams.Adornee = plr.Character
                        Chams.Enabled = ESP.Drawing.Chams.Enabled
                        Chams.FillColor = ESP.Drawing.Chams.FillRGB
                        Chams.OutlineColor = ESP.Drawing.Chams.OutlineRGB
                        if ESP.Drawing.Chams.Thermal then
                            local breathe_effect = math.atan(math.sin(tick() * 2)) * 2 / math.pi
                            Chams.FillTransparency = ESP.Drawing.Chams.Fill_Transparency * breathe_effect * 0.01
                            Chams.OutlineTransparency = ESP.Drawing.Chams.Outline_Transparency * breathe_effect * 0.01
                        end
                        Chams.DepthMode = ESP.Drawing.Chams.VisibleCheck and "Occluded" or "AlwaysOnTop"

                        -- Use actual projected top of avatar for box origin
                        local boxTop = math.min(topScreen.Y, botScreen.Y)
                        Box.Visible = ESP.Drawing.Boxes.Full.Enabled
                        Box.Position = UDim2.new(0, Pos.X - w / 2, 0, boxTop)
                        Box.Size = UDim2.new(0, w, 0, h)
                        if ESP.Drawing.Boxes.Filled.Enabled then
                            Box.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                            Box.BackgroundTransparency = ESP.Drawing.Boxes.GradientFill and ESP.Drawing.Boxes.Filled.Transparency or 1
                            Box.BorderSizePixel = 1
                        else
                            Box.BackgroundTransparency = 1
                        end
                        
                        RotationAngle = RotationAngle + (tick() - Tick) * ESP.Drawing.Boxes.RotationSpeed * math.cos(math.pi / 4 * tick() - math.pi / 2)
                        Gradient1.Rotation = ESP.Drawing.Boxes.Animate and RotationAngle or -45
                        Gradient2.Rotation = ESP.Drawing.Boxes.Animate and RotationAngle or -45
                        Tick = tick()

                        local health = Humanoid.Health / Humanoid.MaxHealth
                        Healthbar.Visible = ESP.Drawing.Healthbar.Enabled
                        Healthbar.Position = UDim2.new(0, Pos.X - w / 2 - 6, 0, boxTop + h * (1 - health))
                        Healthbar.Size = UDim2.new(0, ESP.Drawing.Healthbar.Width, 0, h * health)
                        BehindHealthbar.Visible = ESP.Drawing.Healthbar.Enabled
                        BehindHealthbar.Position = UDim2.new(0, Pos.X - w / 2 - 6, 0, boxTop)
                        BehindHealthbar.Size = UDim2.new(0, ESP.Drawing.Healthbar.Width, 0, h)
                        
                        if ESP.Drawing.Healthbar.HealthText then
                            local healthPercentage = math.floor(health * 100)
                            HealthText.Position = UDim2.new(0, Pos.X - w / 2 - 6, 0, boxTop + h * (1 - healthPercentage / 100) + 3)
                            HealthText.Text = tostring(healthPercentage)
                            HealthText.Visible = Humanoid.Health < Humanoid.MaxHealth and ESP.Drawing.Healthbar.Enabled
                            HealthText.TextColor3 = ESP.Drawing.Healthbar.Lerp and (health >= 0.75 and Color3.fromRGB(0, 255, 0) or health >= 0.5 and Color3.fromRGB(255, 255, 0) or health >= 0.25 and Color3.fromRGB(255, 170, 0) or Color3.fromRGB(255, 0, 0)) or ESP.Drawing.Healthbar.HealthTextRGB
                        else
                            HealthText.Visible = false
                        end

                        Name.Visible = ESP.Drawing.Names.Enabled
                        Name.Text = string.format('(<font color="rgb(%d, %d, %d)">E</font>) %s', 0, 0, 0, plr.Name)
                        Name.Position = UDim2.new(0, Pos.X, 0, boxTop - 9)

                        if ESP.Drawing.Distances.Enabled then
                            Weapon.Position = UDim2.new(0, Pos.X, 0, boxTop + h + 8)
                            Name.Text = Name.Text .. string.format(" [%d]", math.floor(Dist))
                        end

                        Weapon.Text = "none"
                        Weapon.Visible = ESP.Drawing.Weapons.Enabled
                    else
                        HideESP()
                    end
                else
                    HideESP()
                end
            end)
        end

        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer then coroutine.wrap(CreateESP)(v) end      
        end
        Players.PlayerAdded:Connect(function(v)
            coroutine.wrap(CreateESP)(v)
        end)
        
        return ESP
    end

    local GlobalESP = initESP()

    -- ============================================================
    -- COMBAT / AIMBOT / TRIGGERBOT LOGIC
    -- ============================================================
    local function initCombat()
        local Mouse = LocalPlayer:GetMouse()
        local UserInputService = game:GetService("UserInputService")
        local RunService = game:GetService("RunService")

        -- ── Triggerbot ──────────────────────────────────────────────────────
        local TB = {
            Hotkey      = Enum.KeyCode.T,
            HotkeyToggle= true,
            Toggle      = false,
            -- Detection box (matches goodnight config: Width=3, Height=5)
            BoxW        = 3,
            BoxH        = 5,
            MaxDistance = 150,      -- studs
            Prediction  = 0.12,     -- velocity prediction
            WallCheck   = true,
            KnockedCheck= true,
            Cooldown    = 0.05,
        }
        local tbLastShot = 0

        UserInputService.InputBegan:Connect(function(input, gpe)
            if gpe then return end
            if TB.HotkeyToggle then
                if input.KeyCode == TB.Hotkey then TB.Toggle = not TB.Toggle end
            else
                if input.KeyCode == TB.Hotkey then TB.Toggle = true end
            end
        end)
        UserInputService.InputEnded:Connect(function(input, gpe)
            if not TB.HotkeyToggle and input.KeyCode == TB.Hotkey then TB.Toggle = false end
        end)

        -- Returns true if target is behind a wall
        local function tbWallCheck(hrp)
            local cam = Workspace.CurrentCamera
            local rp  = RaycastParams.new()
            rp.FilterType = Enum.RaycastFilterType.Blacklist
            rp.FilterDescendantsInstances = {LocalPlayer.Character or {}, cam}
            local dir = hrp.Position - cam.CFrame.Position
            local res = Workspace:Raycast(cam.CFrame.Position, dir, rp)
            return res ~= nil and not res.Instance:IsDescendantOf(hrp.Parent)
        end

        -- Returns true if player is knocked (Da Hood / Yuu Hood)
        local function tbIsKnocked(p)
            if not p.Character then return false end
            local be = p.Character:FindFirstChild("BodyEffects")
            if be then local ko = be:FindFirstChild("K.O"); if ko and ko.Value then return true end end
            return p.Character:FindFirstChild("GRABBING_CONSTRAINT") ~= nil
        end

        -- Box-overlap detection: projects all enemy parts to screen and checks
        -- if any land inside a small box around the screen center.
        -- This matches the goodnight.llc approach (Width/Height box, predicted pos).
        local function getPlayerInBox()
            local cam    = Workspace.CurrentCamera
            local vp     = cam.ViewportSize
            local cx, cy = vp.X / 2, vp.Y / 2
            local hw, hh = TB.BoxW * 10, TB.BoxH * 10  -- scale to pixels

            local best, bestDist = nil, math.huge

            for _, p in pairs(Players:GetPlayers()) do
                if p == LocalPlayer then continue end
                if not p.Character then continue end
                local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                local hum = p.Character:FindFirstChild("Humanoid")
                if not hrp or not hum or hum.Health <= 0 then continue end

                -- Distance check
                local dist = (Workspace.CurrentCamera.CFrame.Position - hrp.Position).Magnitude
                if dist > TB.MaxDistance * 3.5 then continue end  -- studs to game units

                -- Knocked check
                if TB.KnockedCheck and tbIsKnocked(p) then continue end

                -- Check Head first (priority), fallback HRP
                local partsToCheck = {"Head", "UpperTorso", "HumanoidRootPart"}
                for _, partName in ipairs(partsToCheck) do
                    local part = p.Character:FindFirstChild(partName)
                    if not part then continue end

                    -- Predicted position
                    local predictedPos = part.Position + hrp.Velocity * TB.Prediction
                    local screenPos, onScreen = cam:WorldToViewportPoint(predictedPos)
                    if not onScreen then continue end

                    local sx, sy = screenPos.X, screenPos.Y
                    -- Box overlap test
                    if math.abs(sx - cx) <= hw and math.abs(sy - cy) <= hh then
                        -- Wall check only if needed
                        if TB.WallCheck and tbWallCheck(hrp) then continue end

                        local d = (Vector2.new(sx, sy) - Vector2.new(cx, cy)).Magnitude
                        if d < bestDist then
                            bestDist = d
                            best = p
                        end
                        break  -- found a valid part for this player, stop checking parts
                    end
                end
            end
            return best
        end

        RunService.Heartbeat:Connect(function()
            if not TB.Toggle then return end
            local now = tick()
            if now - tbLastShot < TB.Cooldown then return end

            local hitPlayer = getPlayerInBox()
            if not hitPlayer then return end

            tbLastShot = now
            -- mouse1click is the most reliable across executors
            if type(mouse1click) == "function" then
                mouse1click()
            elseif type(mouse1press) == "function" and type(mouse1release) == "function" then
                mouse1press()
                task.delay(0.008, function() mouse1release() end)
            end
        end)

        -- ── Aim Assist ───────────────────────────────────────────────────────
        local AA = {
            Enabled       = false,
            FollowMode    = "Camera",   -- "Camera" or "Mouse"
            FOV           = 120,
            ShowFOV       = true,
            FOVColor      = Color3.fromRGB(0, 255, 255),
            AimPart       = "Head",
            -- Smoothness: {enabled, value} — lower value = smoother/slower
            SmoothnessOn  = true,
            Smoothness    = 0.025,
            -- Prediction
            PredictionOn  = true,
            AutoPrediction= true,       -- uses bullet speed + ping + net delay
            Prediction    = 0.128,      -- manual value if AutoPrediction off
        }

        local aaFovCircle
        if type(Drawing) == "table" and type(Drawing.new) == "function" then
            aaFovCircle = Drawing.new("Circle")
            aaFovCircle.Visible   = false
            aaFovCircle.Filled    = false
            aaFovCircle.Thickness = 1.5
            aaFovCircle.Color     = AA.FOVColor
        end

        -- Auto prediction: derives prediction from bullet speed, ping and server delay
        local function aaGetAutoPrediction()
            local ping = 0
            pcall(function()
                local pingStr = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValueString()
                local parts   = string.split(pingStr, "(")
                ping = tonumber(parts[1]) or 0
            end)
            -- Map ping to prediction value (same table as silent aim)
            local pingMap = {
                {190,0.180},{180,0.170},{170,0.165},{160,0.1574},{150,0.1555},
                {140,0.141},{130,0.1344},{120,0.1344},{110,0.1300},{100,0.1295},
                {90,0.1295},{80,0.1300},{70,0.1290},{60,0.1250},{50,0.1230},
                {40,0.1190},{30,0.1100},{20,0.1000},
            }
            for _, entry in ipairs(pingMap) do
                if ping < entry[1] then return entry[2] end
            end
            return 0.128
        end

        -- Persistent target: stays on current target until dead/left/out of FOV
        local aaPersistTarget = nil

        local function aaIsTargetValid(part)
            if not part or not part.Parent then return false end
            local hum = part.Parent:FindFirstChild("Humanoid")
            if not hum or hum.Health <= 0 then return false end
            local cam = Workspace.CurrentCamera
            local pos, vis = cam:WorldToViewportPoint(part.Position)
            if not vis then return false end
            local center = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
            return (Vector2.new(pos.X, pos.Y) - center).Magnitude <= AA.FOV * 1.5
        end

        -- Returns nearest visible player part within FOV
        local function aaGetTarget()
            -- Stick with current target if still valid in FOV
            if aaPersistTarget and aaIsTargetValid(aaPersistTarget) then
                return aaPersistTarget
            end
            -- Current target lost — find a new one
            local cam    = Workspace.CurrentCamera
            local vp     = cam.ViewportSize
            local center = Vector2.new(vp.X / 2, vp.Y / 2)
            local radius = AA.FOV
            local best, bestDist = nil, radius

            for _, v in pairs(Players:GetPlayers()) do
                if v == LocalPlayer then continue end
                if not v.Character then continue end
                local part = v.Character:FindFirstChild(AA.AimPart)
                          or v.Character:FindFirstChild("HumanoidRootPart")
                if not part then continue end
                local hum = v.Character:FindFirstChild("Humanoid")
                if not hum or hum.Health <= 0 then continue end

                local pos, vis = cam:WorldToViewportPoint(part.Position)
                if not vis then continue end

                local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                if d < bestDist then
                    bestDist = d
                    best = part
                end
            end
            aaPersistTarget = best
            return best
        end

        -- Update auto prediction every 2s
        local aaPredLastUpdate = 0
        local aaPredCurrent    = AA.Prediction

        RunService.Heartbeat:Connect(function()
            if not AA.Enabled then return end
            if AA.AutoPrediction and tick() - aaPredLastUpdate > 2 then
                aaPredCurrent    = aaGetAutoPrediction()
                aaPredLastUpdate = tick()
            end
        end)

        RunService.RenderStepped:Connect(function()
            local cam = Workspace.CurrentCamera
            local vp  = cam.ViewportSize
            local center = Vector2.new(vp.X / 2, vp.Y / 2)

            -- FOV circle at screen center
            if aaFovCircle then
                aaFovCircle.Visible   = AA.Enabled and AA.ShowFOV
                aaFovCircle.Radius    = AA.FOV
                aaFovCircle.Color     = AA.FOVColor
                aaFovCircle.Position  = center
            end

            if not AA.Enabled then return end

            local target = aaGetTarget()
            if not target then return end
            if not target.Parent then return end

            local hrp = target.Parent:FindFirstChild("HumanoidRootPart")
            local vel = hrp and hrp.Velocity or Vector3.new(0, 0, 0)
            local pred = AA.PredictionOn and (AA.AutoPrediction and aaPredCurrent or AA.Prediction) or 0

            -- Predicted world position
            local aimPos = target.Position + vel * pred

            -- Smooth factor: lower Smoothness = smoother lerp
            local alpha = AA.SmoothnessOn and AA.Smoothness or 1

            if AA.FollowMode == "Camera" then
                -- Rotate camera toward target
                local targetCF = CFrame.new(cam.CFrame.Position, aimPos)
                cam.CFrame = cam.CFrame:Lerp(targetCF, alpha)

            elseif AA.FollowMode == "Mouse" then
                -- Move mouse cursor toward the target screen position
                local screenPos = cam:WorldToViewportPoint(aimPos)
                local curMouse  = Vector2.new(
                    game:GetService("UserInputService"):GetMouseLocation().X,
                    game:GetService("UserInputService"):GetMouseLocation().Y
                )
                local targetScreen = Vector2.new(screenPos.X, screenPos.Y)
                local newPos = curMouse:Lerp(targetScreen, alpha)
                if type(mousemoveabs) == "function" then
                    mousemoveabs(math.floor(newPos.X), math.floor(newPos.Y))
                end
            end
        end)

        return TB, AA
    end

    local TriggerbotConfig, AimAssistConfig = initCombat()

