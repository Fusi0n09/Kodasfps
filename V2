            return p and p ~= LocalPlayer
                and p.Character
                and p.Character:FindFirstChild("HumanoidRootPart")
                and p.Character:FindFirstChild("Humanoid")
                and p.Character.Humanoid.Health > 0
        end

        local function taIsVisible(part)
            local rp = RaycastParams.new()
            rp.FilterType = Enum.RaycastFilterType.Blacklist
            rp.FilterDescendantsInstances = {LocalPlayer.Character or {}}
            local dir = part.Position - Camera.CFrame.Position
            local res = Workspace:Raycast(Camera.CFrame.Position, dir, rp)
            return res == nil or res.Instance:IsDescendantOf(part.Parent)
        end

        local function taIsInAir(p)
            local hum = p.Character and p.Character:FindFirstChildOfClass("Humanoid")
            if not hum then return false end
            local s = hum:GetState()
            return s == Enum.HumanoidStateType.Freefall or s == Enum.HumanoidStateType.Jumping
        end

        local function taIsKnocked(p)
            if not p.Character then return false end
            local be = p.Character:FindFirstChild("BodyEffects")
            if be then local ko = be:FindFirstChild("K.O"); if ko and ko.Value then return true end end
            return p.Character:FindFirstChild("GRABBING_CONSTRAINT") ~= nil
        end

        local function taClosestBodyPart(p)
            local cam = Workspace.CurrentCamera
            local vp  = cam.ViewportSize
            local ctr = Vector2.new(vp.X/2, vp.Y/2)
            local best, bestD = nil, math.huge
            for _, part in pairs(p.Character:GetChildren()) do
                if part:IsA("BasePart") then
                    local pos, on = cam:WorldToViewportPoint(part.Position)
                    if on then
                        local d = (Vector2.new(pos.X, pos.Y) - ctr).Magnitude
                        if d < bestD then bestD = d; best = part end
                    end
                end
            end
            return best
        end

        local function taRandomBodyPart(p)
            local mesh = {}
            for _, v in pairs(p.Character:GetChildren()) do
                if v:IsA("MeshPart") then table.insert(mesh, v) end
            end
            return #mesh > 0 and mesh[math.random(1,#mesh)] or p.Character:FindFirstChild("HumanoidRootPart")
        end

        local resolverCache = {}
        local function taResolveVel(p)
            local hrp = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then return Vector3.new(0,0,0) end
            if TA.ResolverMethod == "MoveDirection" then
                local hum = p.Character:FindFirstChildOfClass("Humanoid")
                return hum and (hum.MoveDirection * hum.WalkSpeed) or Vector3.new(0,0,0)
            end
            local key = p.UserId
            local now = tick()
            if not resolverCache[key] then resolverCache[key] = {pos = hrp.Position, t = now} end
            local dt  = now - resolverCache[key].t
            local vel = dt > 0 and (hrp.Position - resolverCache[key].pos) / dt or hrp.Velocity
            if dt >= TA.UpdateTime/1000 then resolverCache[key] = {pos = hrp.Position, t = now} end
            return vel
        end

        local function taNearestPlayer()
            local cam    = Workspace.CurrentCamera
            local vpSize = cam.ViewportSize
            local center = Vector2.new(vpSize.X/2, vpSize.Y/2)
            local radius = TA.UseFOV and TA.FOVRadius or math.huge
            local best, bestD = nil, radius
            for _, p in pairs(Players:GetPlayers()) do
                if not taIsValid(p) then continue end
                if TA.UseChecks then
                    if TA.CheckKnocked and taIsKnocked(p) then continue end
                    if TA.CheckWall and not taIsVisible(p.Character.HumanoidRootPart) then continue end
                end
                local hrp = p.Character.HumanoidRootPart
                local pos, onScreen = cam:WorldToViewportPoint(hrp.Position)
                if not onScreen then continue end
                if not taIsVisible(hrp) then continue end
                local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                if d < bestD then bestD = d; best = p end
            end
            return best
        end

        local function taGetAimPart(p)
            if TA.RandomBodyPart    then return taRandomBodyPart(p) end
            if TA.ClosestBodyPart   then return taClosestBodyPart(p) end
            if TA.UseAirAimPart and taIsInAir(p) then
                return p.Character:FindFirstChild(TA.AirAimPart) or p.Character:FindFirstChild("HumanoidRootPart")
            end
            return p.Character:FindFirstChild(TA.AimPart) or p.Character:FindFirstChild("HumanoidRootPart")
        end

        local function taGetPredicted(p)
            if not taIsValid(p) then return nil end
            local part = taGetAimPart(p)
            if not part then return nil end
            local hrp  = p.Character.HumanoidRootPart
            local vel  = TA.ResolverEnabled and taResolveVel(p) or hrp.Velocity
            if TA.AntiGroundShots and taIsInAir(p) then
                local goingDown = vel:Dot(Vector3.new(0,-1,0))
                if goingDown > 0.05 then vel = vel * Vector3.new(1, TA.DampeningFactor, 1) end
            end
            local pred = part.Position + vel * TA.Prediction
            if TA.UseAirOffset and taIsInAir(p) then pred = pred + Vector3.new(0, TA.AirOffset, 0) end
            return pred
        end

        local function taNotify(msg)
            if not TA.Notify then return end
            pcall(function()
                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = "Target Aim", Text = msg, Duration = TA.NotifyDuration
                })
            end)
        end

        local function taSetTarget(p)
            if TAState.target == p then return end
            TAState.target       = p
            TAState.isTargetting = p ~= nil
            if p then taNotify("Targeting " .. (p.DisplayName or p.Name))
            else      taNotify("Untargeting") end
            if not p then taChams.Parent = nil end
        end

        -- Lock is now driven by the UI KeyPicker callback via _G._KodaTA_RequestLock
        -- (set by the LinoriaLib KeyPicker in the Combat tab UI)

        -- Teleport active state is driven by the Settings keybind picker via _G._KodaTA_TpActive

        -- Main heartbeat
        RunService.Heartbeat:Connect(function()
            local cam    = Workspace.CurrentCamera
            local vpSize = cam.ViewportSize
            local center = Vector2.new(vpSize.X/2, vpSize.Y/2)

            -- FOV circle
            if taDrawings.fovCircle then
                taDrawings.fovCircle.Visible      = TA.Enabled and TA.UseFOV and TA.VisualizeFOV
                taDrawings.fovCircle.Radius       = TA.FOVRadius
                taDrawings.fovCircle.Color        = TA.FOVColor
                taDrawings.fovCircle.Transparency = TA.FOVTransparency
                taDrawings.fovCircle.Position     = center
            end

            if not TA.Enabled then
                if taDrawings.tracer then taDrawings.tracer.Visible = false end
                if taDrawings.dot    then taDrawings.dot.Visible    = false end
                taChams.Parent = nil
                taSetTarget(nil)
                _G._KodaTA_RequestLock = nil
                return
            end

            -- Poll KeyPicker lock request (set by UI keybind callback)
            if _G._KodaTA_RequestLock ~= nil then
                if _G._KodaTA_RequestLock == "unlock" then
                    taSetTarget(nil)
                else
                    taSetTarget(taNearestPlayer())
                end
                _G._KodaTA_RequestLock = nil
            end

            -- Auto-switch
            if TA.AutoSwitch then
                local n = taNearestPlayer()
                if n ~= TAState.target then taSetTarget(n) end
            end

            -- Validate target
            if TAState.target and not taIsValid(TAState.target) then taSetTarget(nil) end

            local target = TAState.target

            -- Predicted position
            if target then
                local pp = taGetPredicted(target)
                if pp then TAState.predictedPos = pp end
            end

            -- Look At
            if TA.LookAt and target and taIsValid(target) and LocalPlayer.Character
                and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local root = LocalPlayer.Character.HumanoidRootPart
                local tp   = target.Character.HumanoidRootPart.Position
                root.CFrame = CFrame.new(root.Position, Vector3.new(tp.X, root.Position.Y, tp.Z))
            end

            -- Auto Shoot
            if TA.AutoShoot and target and taIsValid(target)
                and (tick() - TAState.lastAutoShoot) >= 0.1 then
                local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
                if tool then
                    pcall(function() tool:Activate() end)
                    TAState.lastAutoShoot = tick()
                end
            end

            -- Visuals
            if TA.VisualsEnabled and target and taIsValid(target) then
                local ps    = cam:WorldToViewportPoint(TAState.predictedPos)
                local sp2   = Vector2.new(ps.X, ps.Y)
                local onScr = ps.Z > 0

                if taDrawings.tracer then
                    taDrawings.tracer.Visible   = TA.TracerEnabled and onScr
                    taDrawings.tracer.From      = center
                    taDrawings.tracer.To        = sp2
                    taDrawings.tracer.Color     = TA.TracerColor
                    taDrawings.tracer.Thickness = TA.TracerThickness
                end

                if taDrawings.dot then
                    taDrawings.dot.Visible   = TA.DotEnabled and onScr
                    taDrawings.dot.Position  = sp2
                    taDrawings.dot.Color     = TA.DotColor
                    taDrawings.dot.Radius    = TA.DotSize
                end

                if TA.ChamsEnabled then
                    taChams.FillColor    = TA.ChamsFillColor
                    taChams.OutlineColor = TA.ChamsOutlineColor
                    taChams.Parent       = target.Character
                else
                    taChams.Parent = nil
                end
            else
                if taDrawings.tracer then taDrawings.tracer.Visible = false end
                if taDrawings.dot    then taDrawings.dot.Visible    = false end
                taChams.Parent = nil
            end

            -- Teleport
            if TA.TeleportEnabled and _G._KodaTA_TpActive and target and taIsValid(target)
                and LocalPlayer.Character
                and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local root = LocalPlayer.Character.HumanoidRootPart
                local tHRP = target.Character.HumanoidRootPart
                local cf
                if TA.TeleportType == "Strafe" then
                    local t = tick()
                    cf = CFrame.new(tHRP.Position)
                        * CFrame.Angles(0, 2*math.pi*t*TA.TeleportStrafeSpeed % (2*math.pi), 0)
                        * CFrame.new(0, TA.TeleportStrafeHeight, TA.TeleportStrafeDistance)
                else
                    local r = TA.TeleportRandomization
                    cf = tHRP.CFrame + Vector3.new(
                        math.random(-r*10, r*10)/10, 0,
                        math.random(-r*10, r*10)/10)
                end
                pcall(function() root.CFrame = cf end)
            end
        end)

        -- Hook tool activation: snap camera AND redirect the shot remote to target
        local taTConn
        local function taFireRemote(predictedPos)
            -- Mirror Silent Aim remote logic for both supported games
            local RS  = game:GetService("ReplicatedStorage")
            local gid = game.PlaceId
            local pv  = Vector3.new(predictedPos.X, predictedPos.Y, predictedPos.Z)
            -- Da Strike / Da Uphill / Yuu Hood
            local MAINEVENT = RS:FindFirstChild("MAINEVENT") or RS:FindFirstChild("MainEvent")
            -- Da Hood uses UpdateMousePos, others use MOUSE
            local isDaHood = (gid == 2788229376 or gid == 7213786345)
            if isDaHood then
                local r = RS:FindFirstChild("MainEvent") or RS:FindFirstChild("MAINEVENT")
                if r then pcall(function() r:FireServer("UpdateMousePos", pv) end) end
            else
                if MAINEVENT then pcall(function() MAINEVENT:FireServer("MOUSE", pv) end) end
            end
            _G.KodaFPS_PlayHitSound = true
        end

        local function taHookChar(char)
            char.ChildAdded:Connect(function(child)
                if not child:IsA("Tool") then return end
                if taTConn then taTConn:Disconnect() end
                taTConn = child.Activated:Connect(function()
                    if not TA.Enabled or not TAState.target then return end
                    local pp = taGetPredicted(TAState.target)
                    if not pp then return end
                    -- 1. Snap camera toward predicted position (smooth)
                    local cam = Workspace.CurrentCamera
                    cam.CFrame = cam.CFrame:Lerp(CFrame.new(cam.CFrame.Position, pp), TA.Prediction)
                    -- 2. Fire game remote so the server registers the hit at predicted pos
                    taFireRemote(pp)
                end)
            end)
        end
        if LocalPlayer.Character then taHookChar(LocalPlayer.Character) end
        LocalPlayer.CharacterAdded:Connect(function(char) taSetTarget(nil); taHookChar(char) end)

        return TA, TAState
    end

