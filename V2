    -- ── Fake Position (Position Desync) Backend ──────────────────────────
    local FakePos = {
        Enabled = false,
    }

    local fpRealCFrame = nil  -- stores the real HRP CFrame each tick

    RunService.Heartbeat:Connect(function()
        if not FakePos.Enabled then return end
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        -- Save real position before faking
        fpRealCFrame = hrp.CFrame
        -- Teleport to desync offset (nan/inf)
        pcall(function()
            hrp.CFrame = hrp.CFrame * CFrame.new(9e9, 0/0, math.huge)
        end)
        RunService.RenderStepped:Wait()
        -- Restore real position immediately after render
        pcall(function()
            hrp.CFrame = fpRealCFrame
        end)
    end)

    -- __index hook: return saved CFrame so the game reads correct position
    if type(hookmetamethod) == "function" and type(newcclosure) == "function" then
        local fpOrigIndex
        fpOrigIndex = hookmetamethod(game, "__index", newcclosure(function(self, key)
            if not checkcaller() then
                if key == "CFrame" and FakePos.Enabled and fpRealCFrame ~= nil then
                    local char = LocalPlayer.Character
                    if char then
                        local hrp = char:FindFirstChild("HumanoidRootPart")
                        local hum = char:FindFirstChild("Humanoid")
                        if hrp and self == hrp and hum and hum.Health > 0 then
                            return fpRealCFrame
                        end
                    end
                end
            end
            return fpOrigIndex(self, key)
        end))
    end

    local function fpDisable()
        FakePos.Enabled = false
        local char = LocalPlayer.Character
        if char and fpRealCFrame then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then pcall(function() hrp.CFrame = fpRealCFrame end) end
        end
    end

