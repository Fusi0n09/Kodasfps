    errSg.Parent = game:GetService("CoreGui")
    
    local errBg = Instance.new("Frame")
    errBg.Size = UDim2.new(1, 0, 0, 60)
    errBg.Position = UDim2.new(0, 0, 0, 0)
    errBg.BackgroundColor3 = Color3.fromRGB(200, 30, 30)
    errBg.Parent = errSg
    
    local errTxt = Instance.new("TextLabel")
    errTxt.Size = UDim2.new(1, -20, 1, -10)
    errTxt.Position = UDim2.new(0, 10, 0, 5)
    errTxt.BackgroundTransparency = 1
    errTxt.TextScaled = true
    errTxt.TextColor3 = Color3.fromRGB(255, 255, 255)
    errTxt.Text = "KODASFPS EXECUTION ERROR: " .. tostring(pcallError)
    errTxt.TextWrapped = true
    errTxt.Parent = errBg
    
    warn("KodaFPS script execution failed:")
    warn(tostring(pcallError))
end
