    local function fhGetClosestPlayer()
        local closestDist, closestPart = nil, nil
        local mousePos = UserInputService:GetMouseLocation()
        for _, p in next, Players:GetPlayers() do
            if p ~= LocalPlayer and p.Character then
                local char    = p.Character
                local hitPart = char:FindFirstChild(ForceHit.HitPart)
                local hum     = char:FindFirstChild("Humanoid")
                local ff      = char:FindFirstChildOfClass("ForceField")
                if hitPart and hum and hum.Health > 0 and not ff then
                    local screenPos, visible = workspace.CurrentCamera:WorldToScreenPoint(hitPart.Position)
                    if visible then
                        local dist = (mousePos - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                        if dist <= ForceHit.FOV.Radius and (not closestDist or dist < closestDist) then
                            closestDist = dist
                            closestPart = hitPart
                        end
                    end
                end
            end
        end
        return closestPart
    end


