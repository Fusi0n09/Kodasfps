-- Camera lock (with auto-retarget + wall/vis gate)
RunService.RenderStepped:Connect(function()
    if not keyPassed then return end
    if not LockSettings.Enabled then return end

    -- auto-retarget: if target died/left, find new one
    if Locked and LockSettings.AutoRetarget then
        local valid = LockedTarget
            and LockedTarget.Character
            and LockedTarget.Character:FindFirstChildOfClass("Humanoid")
            and LockedTarget.Character:FindFirstChildOfClass("Humanoid").Health > 0
        if not valid then
            LockedTarget = GetClosestTarget()
            if not LockedTarget then Locked = false end
        end
    end

    if Locked and LockedTarget
    and LockedTarget.Character
    and LockedTarget.Character:FindFirstChild("HumanoidRootPart") then
        local Root = LockedTarget.Character.HumanoidRootPart

        -- wall check gate while tracking
        if (LockSettings.WallCheck or LockSettings.VisCheck) and not wallCheck(Root, LockedTarget.Character) then
            if LockSettings.AutoRetarget then
                LockedTarget = GetClosestTarget()
                if not LockedTarget then Locked = false end
            end
            return
        end

        local PredictedPos = Root.Position + (Root.Velocity * LockSettings.Prediction)
        local Current      = Camera.CFrame
        local TargetCF     = CFrame.new(Current.Position, PredictedPos)
        Camera.CFrame      = Current:Lerp(TargetCF, LockSettings.Smoothness)
    end
end)

-- Triggerbot
-- Scans independently (no lock required) - fires when crosshair is near any enemy
local tbHoldMode    = false  -- if true: fire while MB1 held; if false: fire automatically
local tbMouseHeld   = false

local function getTargetUnderCrosshair()
    -- find a player within a small FOV ring around center screen
    local center    = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local threshold = (getgenv().KodasTBRadius or 80)  -- pixels from center to count as "on target"
    for _, Player in pairs(Players:GetPlayers()) do
        if Player == LocalPlayer then continue end
        if not Player.Character then continue end
        local hum = Player.Character:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        if isKnockedOrKO(Player) then continue end
        local root = Player.Character:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        local sp, vis = Camera:WorldToViewportPoint(root.Position)
        if not vis then continue end
        local dist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if dist <= threshold then
            -- also check wall if ecco vis check on
            if EccoConfig.VisibleCheck and not canSeeTarget(root, false) then continue end
            return Player
        end
    end
    return nil
end

local function runTriggerBot()
    if not EccoConfig.TriggerBot.Enabled then return end
    if tbHoldMode and not tbMouseHeld then return end
    if tick()-lastTriggerClick < EccoConfig.TriggerBot.Delay then return end

    local target = getTargetUnderCrosshair()
    if not target then return end

    local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
    if not tool then return end
    tool:Activate()
    lastTriggerClick = tick()
end

