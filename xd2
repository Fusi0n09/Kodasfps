-- Hooks (pcall so they fail silently if not supported)
pcall(function()
    local grm = getrawmetatable(game)
    local oldIndex = grm.__index
    setreadonly(grm, false)
    grm.__index = newcclosure(function(self, key)
        if not checkcaller() and self==Mouse and EccoConfig.SilentAim.Enabled then
            if key=="Hit" then
                if not LockedTarget or not LockedTarget.Character then return oldIndex(self,key) end
                local targetPart = LockedTarget.Character:FindFirstChild(EccoConfig.SilentAim.HitPart) or getClosestBodyPart(LockedTarget.Character)
                if not targetPart or isKnockedOrKO(LockedTarget) then return oldIndex(self,key) end
                if not canSeeTarget(targetPart) then return oldIndex(self,key) end
                return CFrame.new(getPredictedPos(targetPart, LockSettings.Prediction))
            end
        end
        -- void hook
        if not checkcaller() and key=="CFrame" and getgenv()["kodasVoid"] then
            local char = LocalPlayer.Character
            if char and self==char:FindFirstChild("HumanoidRootPart") and storedCF then return storedCF end
        end
        -- destroy cheaters hook
        if not checkcaller() and key=="CFrame" and getgenv()["kodasDestroy"] then
            local char = LocalPlayer.Character
            if char and self==char:FindFirstChild("HumanoidRootPart") and storedCF2 then return storedCF2 end
        end
        return oldIndex(self,key)
    end)
    setreadonly(grm, true)
end)

