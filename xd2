local CURRENT_VERSION = "1.0.3"
local UPDATE_URL = "https://raw.githubusercontent.com/kodasfps/kodasfps/main/version.txt"

local function checkForUpdate()
    task.spawn(function()
        local ok, result = pcall(function()
            local reqFunc = (syn and syn.request) or (typeof(request)=="function" and request) or nil
            if not reqFunc then return end
            local res = reqFunc({Url=UPDATE_URL, Method="GET"})
            if res and res.Body then
                local latest = res.Body:match("^%s*(.-)%s*$") -- trim whitespace
                if latest and latest ~= "" and latest ~= CURRENT_VERSION then
                    notify("update available: v"..latest.."  (you have v"..CURRENT_VERSION..")", 6, Color3.fromRGB(255,200,50))
                end
            end
        end)
    end)
end

