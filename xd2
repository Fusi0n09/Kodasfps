local function Tab(name, index)
    local bx=(index-1)*TAB_BTN_W
    local btn=n("TextButton",{Size=UDim2.new(0,TAB_BTN_W,0,TAB_H),Position=UDim2.new(0,bx,0,0),BackgroundTransparency=1,BorderSizePixel=0,Text=name,TextColor3=DIM,TextSize=12,Font=Enum.Font.Code},TabRow)
    local bar=n("Frame",{Size=UDim2.new(1,0,0,2),Position=UDim2.new(0,0,1,-2),BackgroundColor3=ACCENT,BackgroundTransparency=1,BorderSizePixel=0},btn)
    if index<#TAB_NAMES then
        n("Frame",{Size=UDim2.new(0,1,0,14),Position=UDim2.new(1,-1,0.5,-7),BackgroundColor3=BORDER,BorderSizePixel=0},btn)
    end
    local page=n("Frame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,BorderSizePixel=0,Visible=false},CA)
    local colHolder=n("Frame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1},page)
    n("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,SortOrder=Enum.SortOrder.LayoutOrder},colHolder)
    local td={name=name,btn=btn,bar=bar,page=page,colHolder=colHolder,lCol=nil,rCol=nil,subTabBar=nil,subTabs={}}
    btn.MouseButton1Click:Connect(function() setActiveTab(td) end)
    btn.MouseEnter:Connect(function() if activeTD~=td then tw(btn,{TextColor3=TEXT}) end end)
    btn.MouseLeave:Connect(function() if activeTD~=td then tw(btn,{TextColor3=DIM}) end end)
    table.insert(tabsList,td)
    local obj={}
    function obj:Section(p) p=p or{};return mkSec(getCol(td,p.Side),p.name or "") end
    return obj
end

