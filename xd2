local function getCol(td,side)
    local isR=side=="Right"
    if isR and td.rCol then return td.rCol end
    if not isR and td.lCol then return td.lCol end

    -- Outer ScrollingFrame (handles scrolling)
    local scroll=n("ScrollingFrame",{
        Size=UDim2.new(0.5,0,1,0),
        BackgroundTransparency=1,
        BorderSizePixel=0,
        ScrollBarThickness=3,
        ScrollBarImageColor3=ACCENT,
        CanvasSize=UDim2.new(0,0,0,0),
        ScrollingDirection=Enum.ScrollingDirection.Y,
        LayoutOrder=isR and 2 or 1,
        ClipsDescendants=true,
    },td.colHolder)

    -- Inner Frame that holds actual content (AutomaticSize lives here, not in ScrollingFrame)
    local inner=n("Frame",{
        Size=UDim2.new(1,0,0,0),
        AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundTransparency=1,
        BorderSizePixel=0,
    },scroll)
    n("UIPadding",{PaddingLeft=UDim.new(0,7),PaddingRight=UDim.new(0,7),PaddingTop=UDim.new(0,8),PaddingBottom=UDim.new(0,8)},inner)
    local layout=n("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,5)},inner)

    -- Manually sync canvas size to content height so scrolling works
    local function syncCanvas()
        local pad=16 -- top+bottom padding
        scroll.CanvasSize=UDim2.new(0,0,0,layout.AbsoluteContentSize.Y+pad)
    end
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(syncCanvas)

    if isR then td.rCol=inner else td.lCol=inner end
    if isR and not td.lCol then getCol(td,"Left") end
    return inner
end

