                table.insert(AdonisTables, Table)
            end
        end
    end
    for _, Adonis in pairs(AdonisTables) do
        for _, DetectionFunc in pairs(Adonis) do
            if typeof(DetectionFunc) == "function" then
                hookfunction(DetectionFunc, function()
                    return coroutine.yield(coroutine.running())
                end)
            end
        end
    end
    local g = getgc(true)
    for _, v in pairs(g) do
        if type(v) == "function" then
            local info = debug.getinfo(v)
            if info and (info.name == "CheckTools" or info.name == "ScanForCheats") then
                hookfunction(v, function() return end)
            end
        end
