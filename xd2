            if p.callback then p.callback(state) end
        end)
        row.MouseEnter:Connect(function() tw(row,{BackgroundColor3=Color3.fromRGB(28,28,28)}) end)
        row.MouseLeave:Connect(function() tw(row,{BackgroundColor3=BG3}) end)
        local T={}
        function T:Slider(sp) return S:Slider(sp or{}) end
        function T:Keybind(kp) return S:Keybind(kp or{}) end
        function T:Dropdown(dp) return S:Dropdown(dp or{}) end
        function T:Colorpicker(cp) cp=cp or{}
            local dot=n("Frame",{Size=UDim2.new(0,16,0,10),Position=UDim2.new(1,-20,0.5,-5),BackgroundColor3=cp.color or ACCENT,BorderSizePixel=0,ZIndex=2},row)
            rnd(dot,2) stk(dot)
        end
        return T
    end

    function S:Slider(p) p=p or{}
        local mn,mx=p.min or 0,p.max or 100
        local val=p.default or mn
        local pct=(val-mn)/(mx-mn)
        local f=n("Frame",{Size=UDim2.new(1,0,0,22),BackgroundColor3=BG3,BorderSizePixel=0,ClipsDescendants=true},body)
        rnd(f,2) stk(f)
        local fill=n("Frame",{Size=UDim2.new(pct,0,1,0),BackgroundColor3=ACCENT,BackgroundTransparency=0.2,BorderSizePixel=0},f)
        local lbl=n("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=(p.name and p.name..": " or "")..tostring(val),TextColor3=TEXT,TextSize=12,Font=Enum.Font.Code,ZIndex=2},f)
        local sliding=false
        local function upd(x)
            local t=math.clamp((x-f.AbsolutePosition.X)/f.AbsoluteSize.X,0,1)
            val=math.floor(mn+t*(mx-mn))
            fill.Size=UDim2.new(t,0,1,0)
            lbl.Text=(p.name and p.name..": " or "")..tostring(val)
            if p.callback then p.callback(val) end
        end
        f.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=true;upd(i.Position.X) end end)
        UserInputService.InputChanged:Connect(function(i) if sliding and i.UserInputType==Enum.UserInputType.MouseMovement then upd(i.Position.X) end end)
        UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=false end end)
        return {frame=f,lbl=lbl}
    end

